{% extends 'base.html.twig' %}

{% block title %}Affectation de car - Voyage #{{ voyage.id }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('voyage.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">
            Affecter un car au voyage <strong>{{ voyage.codevoyage }}</strong>
        </h1>
        <p class="text-muted-foreground text-sm">Voyage #{{ voyage.id }} — {{ voyage.provenance }} → {{ voyage.destination }}</p>
    </div>
</div>

<div class="rounded-xl border bg-card shadow-sm p-6">
    {{ form_start(form) }}
        <div class="mb-3">{{ form_row(form.car) }}</div>
        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('voyage.index') }}" class="btn btn-secondary">Annuler</a>
            <button class="btn btn-primary">Créer</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}