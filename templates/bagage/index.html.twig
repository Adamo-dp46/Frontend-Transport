{% extends 'base.html.twig' %}

{% block title %}Gestion des bagages{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des bagages</h1>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('BAGAGE_CREER') %}
        <a href="{{ path('bagage.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Enregistrer un bagage
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Exploitation/BagageTable', {
    items: items,
    meta: meta,
    queryParams: queryParams,
    voyages: voyages,
    canEdit: is_granted('BAGAGE_MODIFIER'),
    canDelete: is_granted('BAGAGE_SUPPRIMER'),
    csrfDelete: csrf_token('delete_bagage'),
    userGareId: app.user.gare ? app.user.gare.id : null,
    isAdmin: is_granted('ROLE_ADMIN') or is_granted('ROLE_SUPER_ADMIN')
}) }} class="mb-3">
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
