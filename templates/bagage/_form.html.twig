<form method="POST" class="space-y-6">
    <div class="card p-6">
        <h2 class="text-lg font-semibold mb-4">Informations du client</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {% if bagage is null %}
            <div class="field sm:col-span-2">
                <label class="label" for="voyage">Voyage (optionel)</label>
                <select id="voyage" name="voyage" class="input">
                    <option value="">-- Choisir un voyage --</option>
                    {% for voyage in voyages %}
                        <option value="{{ voyage.id }}" {{ voyageId is defined and voyageId and voyageId == voyage.id ? 'selected' : '' }}>
                            {{ voyage.codevoyage }} - {{ voyage.provenance }} → {{ voyage.destination }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            {% else %}
            <div class="field sm:col-span-2">
                <label class="label" for="voyage">Voyage (optionel)</label>
                <select id="voyage" name="voyage" class="input">
                    <option value="">-- Choisir un voyage --</option>
                    {% for v in voyages %}
                        <option value="{{ v.id }}" {{ bagage.voyage is not null and bagage.voyage.id == v.id ? 'selected' : '' }}>
                            {{ v.codevoyage }} - {{ v.provenance }} → {{ v.destination }}
                        </option>
                    {% endfor %}
                </select>
                <p class="text-xs text-muted-foreground mt-1">
                    Affecter un voyage changera le statut du bagage en <strong>Embarqué</strong>
                </p>
            </div>
            {% endif %}
            <div class="field sm:col-span-2">
                <label class="label" for="garedescente">Gare de descente</label>
                <select id="garedescente" name="garedescente" class="input" data-current="{{ bagage.garedescente.id ?? '' }}" data-usergare="{{ userGareId ?? '' }}" disabled>
                    <option value="">-- Choisir un voyage d'abord --</option>
                </select>
                <p class="text-xs text-muted-foreground mt-1">
                    {% if userGareId %}Départ depuis votre gare ({{ userGareLibelle }}). {% endif %}Où le client récupère son bagage. Laissé vide = terminus.
                </p>
            </div>
            <div class="field">
                <label class="label" for="nomclient">Nom du client <span class="text-red-500">*</span></label>
                <input type="text" id="nomclient" name="nomclient" class="input" value="{{ bagage.nomclient ?? '' }}" required>
            </div>
            <div class="field">
                <label class="label" for="contactclient">Contact <span class="text-red-500">*</span></label>
                <input type="text" id="contactclient" name="contactclient" class="input" value="{{ bagage.contactclient ?? '' }}" required>
            </div>
        </div>
    </div>

    <div class="card p-6">
        <h2 class="text-lg font-semibold mb-4">Détail du bagage</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="field">
                <label class="label" for="nature">Nature <span class="text-red-500">*</span></label>
                <input type="text" id="nature" name="nature" class="input" value="{{ bagage.nature ?? '' }}" placeholder="ex: valise, sac, carton.." required>
            </div>
            <div class="field">
                <label class="label" for="type">Type <span class="text-red-500">*</span></label>
                <select id="type" name="type" class="input" required>
                    {% for val, label in { LEGER: 'Léger', LOURD: 'Lourd', VOLUMINEUX: 'Volumineux', FRAGILE: 'Fragile' } %}
                        <option value="{{ val }}" {{ (bagage.type ?? 'LEGER') == val ? 'selected' : '' }}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="field">
                <label class="label" for="poids">
                    Poids (kg) <span class="text-red-500">*</span>
                </label>
                <input type="number" id="poids" name="poids" class="input" min="1" value="{{ bagage.poids ?? '' }}" required>
            </div>

            {# Tarif calculé automatiquement #}
            <div class="field">
                <label class="label">Tarif applicable</label>
                <div id="tarif-info" class="rounded-md border bg-muted/30 px-3 py-2 text-sm text-muted-foreground">
                    Saisissez le poids pour voir le tarif applicable
                </div>
            </div>

            {# Montant forcé #}
            <div class="sm:col-span-2">
                <label class="flex items-center gap-2 cursor-pointer mb-3">
                    <input type="checkbox" id="montant_force_check" name="montant_force" value="1" class="checkbox rounded" {{ (bagage.montantforce ?? false) ? 'checked' : '' }}>
                    <span class="text-sm font-medium">Forcer le montant manuellement</span>
                </label>
                <div id="montant_force_wrapper" class="{{ (bagage.montantforce ?? false) ? '' : 'hidden' }}">
                    <label class="label" for="montant">Montant forcé (FCFA)</label>
                    <input type="number" id="montant" name="montant" class="input max-w-xs" min="0" value="{{ (bagage.montantforce ?? false) ? bagage.montant : '' }}">
                </div>
            </div>
        </div>
    </div>

    <div class="flex items-center gap-2">
        <button type="submit" class="btn btn-primary">{{ button }}</button>
        <a href="{{ path('bagage.index') }}" class="btn btn-secondary">Annuler</a>
    </div>
</form>

<script>
document.addEventListener('turbo:load', function () {
    const poidsInput = document.getElementById('poids');
    const tarifInfo = document.getElementById('tarif-info');
    const forceCheck = document.getElementById('montant_force_check');
    const forceWrapper = document.getElementById('montant_force_wrapper');
    const montantInput = document.getElementById('montant');

    const tarifs = {{ tarifbagages|json_encode|raw }}

    // Toggle montant forcé
    forceCheck.addEventListener('change', function () {
        forceWrapper.classList.toggle('hidden', !this.checked);
        if (!this.checked) montantInput.value = '';
    });

    // Calcul automatique du tarif selon le poids
    poidsInput.addEventListener('input', function () {
        const poids = parseFloat(this.value);
        if (isNaN(poids) || poids <= 0) {
            tarifInfo.textContent = 'Saisissez le poids pour voir le tarif applicable';
            tarifInfo.className = 'rounded-md border bg-muted/30 px-3 py-2 text-sm text-muted-foreground';
            return;
        }

        const tarif = tarifs.find(t =>
            poids >= parseFloat(t.poidsmin) &&
            (t.poidsmax === null || poids <= parseFloat(t.poidsmax))
        );

        if (tarif) {
            tarifInfo.innerHTML = `
                <span class="font-medium text-foreground">${tarif.libelle}</span>
                <span class="ml-2 font-bold text-foreground">${parseInt(tarif.montant).toLocaleString('fr-FR')} FCFA</span>
            `;
            tarifInfo.className = 'rounded-md border bg-green-50 px-3 py-2 text-sm text-green-700';

            // Pré-remplir montant forcé si déjà coché
            if (forceCheck.checked && !montantInput.value) {
                montantInput.value = tarif.montant;
            }
        } else {
            tarifInfo.textContent = 'Aucun tarif trouvé pour ce poids — montant forcé obligatoire';
            tarifInfo.className = 'rounded-md border bg-orange-50 px-3 py-2 text-sm text-orange-700';
            // Forcer l'activation du montant manuel
            forceCheck.checked = true;
            forceWrapper.classList.remove('hidden');
        }
    });

    // Trigger au chargement si poids déjà rempli (cas edit)
    if (poidsInput.value) {
        poidsInput.dispatchEvent(new Event('input'));
    }
});
</script>

<script>
// Gare de descente limitée aux arrêts de la ligne du voyage choisi (désactivée tant qu'aucun voyage)
document.addEventListener('turbo:load', function () {
    const voyageSelect   = document.getElementById('voyage');
    const descenteSelect = document.getElementById('garedescente');
    if (!voyageSelect || !descenteSelect) return;

    const current = descenteSelect.dataset.current || '';
    const usergare = descenteSelect.dataset.usergare || '';
    const esc = s => String(s).replace(/[&<>"]/g, c => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;' }[c]));

    function setPlaceholder(text) {
        descenteSelect.innerHTML = '<option value="">' + text + '</option>';
        descenteSelect.disabled = true;
    }

    async function applyArrets(voyageId) {
        if (!voyageId) { setPlaceholder("-- Choisir un voyage d'abord --"); return; }
        try {
            const res  = await fetch('/bagage/arrets/' + voyageId);
            const data = await res.json();
            const all  = data.arrets || [];
            let arrets;
            if (usergare) {
                // Agent rattaché à une gare : la descente ne peut être qu'après SA gare (= origine du bagage)
                const agent = all.find(function (a) { return String(a.id) === String(usergare); });
                if (!agent) { setPlaceholder("Votre gare n'est pas desservie par ce voyage"); return; }
                arrets = all.filter(function (a) { return a.ordre > agent.ordre; });
            } else {
                arrets = all.slice(1); // on exclut l'origine
            }
            if (arrets.length === 0) { setPlaceholder('Aucun arrêt disponible'); return; }
            let html = '<option value="">-- Terminus par défaut --</option>';
            arrets.forEach(function (a) {
                const sel   = String(a.id) === String(current) ? ' selected' : '';
                const ville = a.ville ? ' (' + esc(a.ville) + ')' : '';
                html += '<option value="' + a.id + '"' + sel + '>' + esc(a.libelle) + ville + '</option>';
            });
            descenteSelect.innerHTML = html;
            descenteSelect.disabled = false;
        } catch (e) {
            setPlaceholder('Erreur de chargement');
        }
    }

    voyageSelect.addEventListener('change', function () { applyArrets(this.value); });
    if (voyageSelect.value) { applyArrets(voyageSelect.value); }
});
</script>