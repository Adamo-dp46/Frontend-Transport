{% extends 'base.html.twig' %}

{% block title %}{{ trajet.provenance }} → {{ trajet.destination }}{% endblock %}

{% block body %}
<div class="max-w-[1000px] mx-auto">
    <div class="card p-6 mb-3">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
            <div>
                <div class="flex items-center gap-2 mb-2">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-mono font-medium bg-zinc-100 text-zinc-700 ring-1 ring-zinc-200">
                        {{ trajet.codetrajet }}
                    </span>
                </div>
                <h1 class="text-2xl font-bold flex items-center gap-3">
                    {{ trajet.provenance }}
                    <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12"/>
                    </svg>
                    {{ trajet.destination }}
                </h1>
            </div>
            <div class="text-right shrink-0">
                <p class="text-xs text-muted-foreground uppercase tracking-wide font-medium mb-0.5">Tarif</p>
                <p class="text-2xl font-bold">
                    {{ trajet.tarif.montant|number_format(0, ',', ' ') }} FCFA
                </p>
            </div>
        </div> 
    </div>

    <h3 class="text-3xl font-bold tracking-[-0.55px] leading-[1.2] mb-3">Les voyages liés</h3>
    <div {{ react_component('Collection/VoyagesCollectionTable', {
        voyages: voyages,
        meta: voyagesMeta,
        queryParams: voyagesParams
    }) }}>
        <div class="flex items-center justify-center gap-6">
            <twig:Spinner class="size-8" />
        </div>
    </div>
</div>
{% endblock %}