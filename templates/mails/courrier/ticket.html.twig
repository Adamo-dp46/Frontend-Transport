<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 11px;
            color: #000;
            width: 72mm;
            padding: 4mm;
        }

        .center { text-align: center; }
        .bold { font-weight: bold; }
        .upper { text-transform: uppercase; }

        /* En-tête : sigle à gauche, contact + date à droite */
        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2px;
        }
        .header-sigle {
            font-size: 18px;
            font-weight: 900;
            line-height: 1;
        }
        .header-right {
            text-align: right;
            font-size: 10px;
        }
        .header-agency {
            font-size: 11px;
            font-weight: bold;
        }
        .header-date {
            font-size: 11px;
            font-weight: bold;
        }

        /* Titre principal */
        .title {
            text-align: center;
            font-size: 18px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin: 6px 0 4px;
        }

        /* Ligne simple centrée */
        .info-line {
            text-align: center;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 3px 0;
        }
        .info-line .label {
            font-weight: bold;
        }
        .info-line .value {
            font-weight: bold;
        }

        /* Ligne VALEUR + FRAIS sur la même ligne */
        .valeur-frais {
            display: flex;
            justify-content: center;
            gap: 10mm;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 3px 0;
        }

        /* Bloc CODE */
        .code-line {
            text-align: center;
            font-size: 20px;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 3px;
            margin: 6px 0;
        }
        .code-line .code-label {
            font-size: 16px;
        }

        /* Sections EXPÉDITEUR / DESTINATAIRE */
        .section-title {
            text-align: center;
            font-size: 13px;
            font-weight: 900;
            text-transform: uppercase;
            margin: 5px 0 1px;
        }
        .section-value {
            text-align: center;
            font-size: 13px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 1px 0;
        }
        .section-contact {
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            margin: 1px 0 4px;
        }

        /* REF */
        .ref-line {
            font-size: 13px;
            font-weight: 900;
            text-transform: uppercase;
            margin: 5px 0 2px;
        }

        /* Frais suivi */
        .suivi-line {
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
            margin: 2px 0 5px;
        }

        /* Table colis */
        .colis-table {
            width: 100%;
            border-collapse: collapse;
            margin: 4px 0;
            font-size: 10px;
        }
        .colis-table thead tr th {
            border: 1px solid #000;
            padding: 2px 4px;
            text-align: center;
            font-weight: bold;
            text-transform: uppercase;
            background: #eee;
        }
        .colis-table tbody tr td {
            border: 1px solid #000;
            padding: 2px 4px;
            text-align: center;
        }

        /* Table title */
        .table-title {
            text-align: center;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
            border: 1px solid #000;
            border-bottom: none;
            padding: 2px;
        }

        /* Footer */
        .footer {
            font-size: 8.5px;
            text-align: center;
            margin-top: 6px;
            font-weight: bold;
            text-transform: uppercase;
        }

        .separator { border-top: 1px dashed #000; margin: 3px 0; }
        .separator-solid { border-top: 1px solid #000; margin: 3px 0; }
    </style>
</head>
<body>

    {# ── En-tête ── #}
    <div class="header-top">
        <div>
            <div class="header-sigle bold upper">{{ entreprise.sigle ?? entreprise.libelle }}</div>
            <div class="header-agency upper">{{ entreprise.adresse ?? '' }}</div>
        </div>
        <div class="header-right">
            {% if entreprise.contact1 %}
                <div>{{ entreprise.contact1 }}</div>
            {% endif %}
            {% if entreprise.contact2 %}
                <div>{{ entreprise.contact2 }}</div>
            {% endif %}
            <div class="header-date bold">{{ "now"|date("d/m/Y") }}</div>
        </div>
    </div>

    <div class="separator-solid"></div>

    {# ── Titre ── #}
    <div class="title">Reçu Courrier</div>

    <div class="separator-solid"></div>

    {# ── Destination ── #}
    <div class="info-line upper">
        <span class="label">Destination : </span>
        <span class="value">{{ courrier.garearrivee.libelle }}</span>
    </div>

    {# ── Valeur + Frais ── #}
    <div class="valeur-frais">
        <span>Valeur : {{ courrier.detailcourriers|map(d => d.valeur)|reduce((carry, v) => carry + v, 0)|number_format(0, ',', ' ') }}</span>
        <span>Frais : <strong>{{ courrier.montant|number_format(0, ',', ' ') }}</strong></span>
    </div>

    <div class="separator-solid"></div>

    {# ── Code ── #}
    <div class="code-line">
        <span class="code-label">Code : </span>{{ courrier.codecourrier }}
    </div>

    <div class="separator-solid"></div>

    {# ── Expéditeur ── #}
    <div class="section-title">Expéditeur</div>
    <div class="section-value">{{ courrier.nomexpediteur|upper }}</div>
    <div class="section-contact">{{ courrier.contactexpediteur }}</div>

    <div class="separator-solid"></div>

    {# ── Destinataire ── #}
    <div class="section-title">Destinataire</div>
    <div class="section-value">{{ courrier.nomdestinataire|upper }}</div>
    <div class="section-contact">{{ courrier.contactdestinataire }}</div>

    <div class="separator-solid"></div>

    {# ── Référence voyage ── #}
    {% if courrier.voyage %}
    <div class="ref-line">
        Réf : {{ courrier.voyage.codevoyage }}
    </div>
    {% endif %}

    {# ── Frais suivi SMS ── #}
    {% if courrier.fraissuivi %}
    <div class="suivi-line">
        Frais de suivi SMS : {{ courrier.fraissuivi|number_format(0, ',', ' ') }}
    </div>
    {% endif %}

    {# ── Liste des colis ── #}
    <div class="table-title">Liste des colis</div>
    <table class="colis-table">
        <thead>
            <tr>
                <th>Nature</th>
                <th>Désignation</th>
            </tr>
        </thead>
        <tbody>
            {% for detail in courrier.detailcourriers %}
            <tr>
                <td>{{ detail.nature|upper }}</td>
                <td>{{ detail.designation|upper }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    {# ── Footer ── #}
    <div class="separator-solid"></div>
    <div class="footer">
        <p>NB : Passé un délai de 15 jours {{ entreprise.sigle ?? entreprise.libelle }} pas responsable en cas de perte</p>
        <p>Pas de remboursement après encaissement</p>
    </div>

</body>
</html>