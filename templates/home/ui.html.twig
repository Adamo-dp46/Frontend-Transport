{% extends 'app-base.html.twig' %}

{% block title %}Ui{% endblock %}

{% block body %}
<style>
    body {
        overflow: scroll !important;
    }
</style>
<div class="container py-4">


/*
    - 'tracking-[-55px]' letter-spacing, 'text-base/6' line-height
    - 'shrink-' pour ne pas que la largeur de l'élément soit mangé et ne reduis pas sa taille, à 0 pour ne pas que la largeur de l'élément soit mangé et ne reduis pas sa taille, si on met '10' il va se reduire 10x plus que les autres
    - 'flex-grow: 1' permet de spécifier comment s'étend les éléments, par défaut 0 ne s'agrendi pas, 1 va distribué l'espace restant pour cet élement
    - flex: none; -- L'élément ne grandira pas et ne se rapetissera pas
    - align-items: flex-start; -- Pour éviter que les éléments grandissent et seront placés au début du conteneur
    - 'grid-cols-[1fr_340px]' colonne de grille
    - 'grid place-items-center min-h-[20vh]' ou 'min-h-screen' pour centrer avec une grille
    - 'absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2' pour centre avec position '1/2' = 50% et '-translate-x-1/2' = -50%
    - 'has-[:checked]:bg-primary/5' ou 'has-checked:bg-primary/5' pour un checkbox
    - .divide : largeur du border bottom
    - grid-auto-flow: row;  Permet de changer la manière de s'alligner des éléments
        - row : S'alligne en ligne, par défaut
        - column : Va remplir les éléments par colonnes
*/


<!-- Wrap -->
<div class="flex flex-wrap">
<div class="flex flex-nowrap">

<!-- Enfants flex -->
<div class="flex-1">    <!-- flex: 1 1 0 -->
<div class="flex-auto"> <!-- flex: 1 1 auto -->
<div class="flex-none"> <!-- flex: none -->
```

<!-- Span -->
<div class="col-span-2">  <!-- occupe 2 colonnes -->
<div class="col-span-full"> <!-- occupe toute la largeur -->

<!-- Auto -->
<div class="grid grid-cols-[repeat(auto-fill,minmax(200px,1fr))]">
```

