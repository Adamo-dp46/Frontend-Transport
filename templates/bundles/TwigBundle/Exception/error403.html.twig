{% extends 'base.html.twig' %}

{% block title %}Accès refusé{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap');

  .error-page-wrapper {
    font-family: 'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    padding: 2rem;
  }

  .error-card {
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .error-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid #e4e4e7;
    background-color: #fafafa;
    font-size: 0.75rem;
    font-weight: 500;
    color: #71717a;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .error-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background-color: #f59e0b;
  }

  .error-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    border: 1px solid #e4e4e7;
    background-color: #fafafa;
    margin: 0 auto 1.25rem;
    color: #71717a;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 700;
    line-height: 1;
    color: #09090b;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
  }

  .error-divider {
    width: 2rem;
    height: 2px;
    background-color: #e4e4e7;
    margin: 0 auto 1.25rem;
    border-radius: 9999px;
  }

  .error-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #09090b;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .error-description {
    font-size: 0.875rem;
    color: #71717a;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .error-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid #fef08a;
    background-color: #fefce8;
    text-align: left;
    margin-bottom: 1.75rem;
    color: #854d0e;
    font-size: 0.8125rem;
    line-height: 1.5;
  }

  .error-alert svg {
    flex-shrink: 0;
    margin-top: 1px;
    color: #ca8a04;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    background-color: #09090b;
    color: #fafafa;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color 0.15s ease;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    letter-spacing: -0.005em;
  }

  .btn-primary:hover {
    background-color: #18181b;
    color: #fafafa;
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    background-color: #ffffff;
    color: #09090b;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid #e4e4e7;
    transition: background-color 0.15s ease;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    letter-spacing: -0.005em;
  }

  .btn-secondary:hover {
    background-color: #f4f4f5;
    color: #09090b;
    text-decoration: none;
  }

  .error-meta {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f4f4f5;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: #a1a1aa;
    font-family: 'Geist Mono', ui-monospace, monospace;
  }

  .error-meta-separator {
    color: #d4d4d8;
  }
</style>

<div class="error-page-wrapper">
  <div class="error-card">

    <div class="error-badge">
      <span class="error-badge-dot"></span>
      Accès refusé
    </div>

    <div class="error-icon-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
    </div>

    <div class="error-code">403</div>

    <div class="error-divider"></div>

    <h1 class="error-title">Accès interdit</h1>
    <p class="error-description">
      Vous ne disposez pas des permissions nécessaires pour accéder à cette ressource.
    </p>

    <div class="error-alert">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
        <path d="M12 9v4"/><path d="M12 17h.01"/>
      </svg>
      Si vous pensez qu'il s'agit d'une erreur, veuillez contacter un administrateur ou vous connecter avec un compte autorisé.
    </div>

    <div class="error-actions">
      <a href="{{ path('home') }}" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Retour à l'accueil
      </a>
      <a href="javascript:history.back()" class="btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Page précédente
      </a>
    </div>

    <div class="error-meta">
      <span>HTTP {{ status_code }}</span>
      <span class="error-meta-separator">·</span>
      <span>{{ status_text }}</span>
    </div>

  </div>
</div>
{% endblock %}