{#
    Macros partagées pour les pages de statistiques (style aligné sur la Caisse).
    Usage : {% import 'home/_stats.html.twig' as s %}
#}

{# ── En-tête de page avec filtre période ──────────────────────────── #}
{% macro pageHeader(title, eyebrow, route, debut, fin) %}
<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between mb-8">
    <div>
        {% if eyebrow %}<p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-blue-600 mb-1.5">{{ eyebrow }}</p>{% endif %}
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.1]">{{ title }}</h1>
        <p class="text-sm text-muted-foreground mt-2 flex items-center gap-1.5">
            <svg class="size-4 shrink-0" fill="none" stroke="currentColor" stroke-width="1.7" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            Du {{ debut|date('d/m/Y') }} au {{ fin|date('d/m/Y') }}
        </p>
    </div>
    <form method="get" action="{{ path(route) }}" class="flex items-center gap-1.5 rounded-xl border bg-card p-1.5 shadow-sm max-sm:w-full">
        <input type="date" name="debut" value="{{ debut }}" class="input input-sm border-0 bg-transparent shadow-none" />
        <span class="text-muted-foreground text-sm">→</span>
        <input type="date" name="fin" value="{{ fin }}" class="input input-sm border-0 bg-transparent shadow-none" />
        <button type="submit" class="inline-flex items-center gap-1.5 rounded-lg bg-blue-600 px-3 py-2 text-sm font-medium text-white hover:bg-blue-700 transition shrink-0">
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 5.25h16.5m-13.5 6h10.5m-7.5 6h4.5" />
            </svg>
            Filtrer
        </button>
    </form>
</div>
{% endmacro %}

{# ── Titre de section ─────────────────────────────────────────────── #}
{% macro sectionTitle(title, sub) %}
<div class="flex items-end justify-between mb-4">
    <h2 class="text-lg font-medium">{{ title }}</h2>
    {% if sub %}<span class="text-xs text-muted-foreground">{{ sub }}</span>{% endif %}
</div>
{% endmacro %}

