<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Welcome!{% endblock %} | Transport</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <!-- Google -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&family=Manrope:wght@200..800&display=swap" rel="stylesheet">
        <!-- ! -->
        <script>
            document.documentElement.classList.toggle(
                'dark',
                localStorage.theme === 'dark' ||
                (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)
            ) /*
                - Pour éviter le flash au chargement 'FOUC' ce qui applique le thème instantanément et ne doit pas être dans 'turbo:load' car il doit s'exécuter avant le rendu
            */

            if(localStorage.getItem('sidebar-collapsed') === 'true') {
                document.documentElement.classList.add('sidebar-pre-collapsed');
            }
        </script>
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <style>
        .sidebar-pre-collapsed .sidebar {
            width: var(--sidebar-collapsed-w) !important;
            min-width: var(--sidebar-collapsed-w) !important;
        }
    </style>
    <body>
        <div class="shell">
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
            <!-- ═══ SIDEBAR (from Dashboard 1) ═══ -->
            <aside class="sidebar" id="sidebar">
                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">
                        <svg width="16" height="16"><use href="{{ asset('sprite.svg') }}#logo"></use></svg>
                    </div>
                    <span class="sidebar-logo-text sb-text">iTransport</span>
                </div>

                <nav class="sidebar-nav">
                    <div class="sidebar-section">
                        <div class="sb-section-title">Principal</div>

                        <a href="{{ path('home') }}" class="nav-link {{ app.current_route starts with 'home' ? 'active' : '' }}" data-nav data-tooltip="Dashboard">
                            <svg class="nav-icon" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#dashbord"></use></svg>
                            <span class="sb-text">Tableau de bord</span>
                        </a>

                        <button class="nav-link" data-submenu="sub-stock" title="Stock & Approvisionnement"> {# On peut mettre un lien 'a' #}
                            <svg class="nav-icon" aria-hidden="true">
                                <use href="{{ asset('sprite.svg') }}#stock"></use>
                            </svg>
                            <span class="sb-text">Stock & Approvisionnement</span>
                            {# <span class="nav-badge">12</span> #}
                            <svg class="submenu-arrow" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron"></use></svg>
                        </button>
                        <div class="submenu" id="sub-stock">
                            <div class="submenu-inner">
                                {% if is_granted('TYPEPIECE_VOIR') %}
                                <a href="{{ path('typepiece.index') }}" class="sub-link {{ app.current_route starts with 'typepiece.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Type de pièce
                                </a>
                                {% endif %}
                                {% if is_granted('MARQUEPIECE_VOIR') %}
                                <a href="{{ path('marquepiece.index') }}" class="sub-link {{ app.current_route starts with 'marquepiece.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Marque de pièce {# <span class="sub-badge-warn">8</span> #}
                                </a>
                                {% endif %}
                                {% if is_granted('MODEL_VOIR') %}
                                <a href="{{ path('model.index') }}" class="sub-link {{ app.current_route starts with 'model.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Modèle de pièce
                                </a>
                                {% endif %}
                                {% if is_granted('FOURNISSEUR_VOIR') %}
                                <a href="{{ path('fournisseur.index') }}" class="sub-link {{ app.current_route starts with 'fournisseur.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Fournisseur
                                </a>
                                {% endif %}
                                {% if is_granted('PIECE_VOIR') %}
                                <a href="{{ path('piece.index') }}" class="sub-link {{ app.current_route starts with 'piece.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Pièce
                                </a>
                                {% endif %}
                                {% if is_granted('APPROVISIONNEMENT_VOIR') %}
                                <a href="{{ path('approvisionnement.index') }}" class="sub-link {{ app.current_route starts with 'approvisionnement.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Approvisionnement
                                </a>
                                {% endif %}
                            </div>
                        </div>

                        <button class="nav-link" data-submenu="sub-flotte" title="Flotte & Maintenance">
                            <svg class="nav-icon" aria-hidden="true">
                                <use href="{{ asset('sprite.svg') }}#flotte"></use>
                            </svg>
                            <span class="sb-text">Flotte & Maintenance</span>
                            <svg class="submenu-arrow" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron"></use></svg>
                        </button>
                        <div class="submenu" id="sub-flotte">
                            <div class="submenu-inner">
                                {% if is_granted('MARQUE_VOIR') %}
                                <a href="{{ path('marque.index') }}" class="sub-link {{ app.current_route starts with 'marque.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Marque
                                </a>
                                {% endif %}
                                {% if is_granted('MODELVEHICULE_VOIR') %}
                                <a href="{{ path('modelvehicule.index') }}" class="sub-link {{ app.current_route starts with 'modelvehicule.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Modèle de véhicule
                                </a>
                                {% endif %}
                                {% if is_granted('TYPEVEHICULE_VOIR') %}
                                <a href="{{ path('typevehicule.index') }}" class="sub-link {{ app.current_route starts with 'typevehicule.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Type de véhicule
                                </a>
                                {% endif %}
                                {% if is_granted('CAR_VOIR') %}
                                <a href="{{ path('car.index') }}" class="sub-link {{ app.current_route starts with 'car.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Véhicule
                                </a>
                                {% endif %}
                                {% if is_granted('TYPEPANNE_VOIR') %}
                                <a href="{{ path('typepanne.index') }}" class="sub-link {{ app.current_route starts with 'typepanne.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Type de panne
                                </a>
                                {% endif %}
                                {% if is_granted('DEPANNAGE_VOIR') %}
                                <a href="{{ path('depannage.index') }}" class="sub-link {{ app.current_route starts with 'depannage.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Dépannage
                                </a>
                                {% endif %}
