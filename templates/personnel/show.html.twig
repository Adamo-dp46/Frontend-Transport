{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}Personnel - {{ personnel.prenom }} {{ personnel.nom }}{% endblock %}

{% set nbVoyages = personnel.voyagesCount %}
{% set nbDepannages = personnel.depannagesCount %}
{% set nbAffectations = personnel.affectationsCount %}

{% block body %}
<div class="max-w-[1100px] mx-auto">

    {# En-tête #}
    <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
        <div class="min-w-0">
            <a href="{{ path('personnel.index') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-2">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                Retour au personnel
            </a>
            <div class="flex items-center gap-2 flex-wrap mb-0.5">
                <p class="text-xs uppercase tracking-wide text-muted-foreground">Personnel</p>
                {% if personnel.typepersonnel %}{{ ui.badge(personnel.typepersonnel.libelle, 'blue') }}{% endif %}
            </div>
            <h1 class="text-3xl font-light tracking-[-0.5px] leading-[1.2] break-words">{{ personnel.prenom }} {{ personnel.nom }}</h1>
            <p class="text-sm text-muted-foreground mt-1 font-mono">{{ personnel.code }}</p>
        </div>
        {% if is_granted('PERSONNEL_MODIFIER') %}
        <div class="flex items-center gap-2 flex-wrap shrink-0">
            <a href="{{ path('personnel.edit', { id: personnel.id }) }}" class="btn btn-primary">
                <svg class="nav-item-icon" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#edit"></use></svg>
                Modifier
            </a>
        </div>
        {% endif %}
    </div>

    {# KPI #}
    <div class="grid grid-cols-3 gap-3 mb-5">
        {{ ui.stat('Affectations', nbAffectations) }}
        <div class="card p-4">
            <p class="text-xs text-muted-foreground">Voyages</p>
            <p class="text-2xl font-semibold tabular-nums text-blue-600 dark:text-blue-400 mt-0.5">{{ nbVoyages }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground">Dépannages</p>
            <p class="text-2xl font-semibold tabular-nums mt-0.5 {{ nbDepannages > 0 ? 'text-orange-600 dark:text-orange-400' : '' }}">{{ nbDepannages }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-4">
            {# Informations #}
            <div class="card p-6">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">Informations</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                    {{ ui.field('Code', personnel.code, true) }}
                    {{ ui.field('Nom', personnel.nom) }}
                    {{ ui.field('Prénom', personnel.prenom) }}
                    {{ ui.field('Contact', personnel.contact ? '<a href="tel:' ~ personnel.contact ~ '" class="text-primary hover:underline">' ~ personnel.contact ~ '</a>' : null, false, true) }}
                    {{ ui.field('Type', personnel.typepersonnel.libelle ?? null) }}
                    {{ ui.field("Date d'embauche", personnel.dateembauche ? personnel.dateembauche|date('d/m/Y') : null) }}
                    {{ ui.field('Enregistré le', personnel.createdAt ? personnel.createdAt|date('d/m/Y') : null) }}
                </div>
            </div>

            {# Voyages #}
            <div class="card overflow-hidden">
                <div class="flex items-center justify-between px-6 py-4 border-b border-border">
                    <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Voyages effectués</h2>
                    <span class="text-xs text-muted-foreground">{{ nbVoyages }}</span>
                </div>
                <div {{ react_component('Collection/VoyagesCollectionTable', {
                    voyages: voyages,
                    meta: voyagesMeta,
                    queryParams: voyagesParams,
                    urlPrefix: 'v'
                }) }}>
                    <div class="flex items-center justify-center gap-6"><twig:Spinner class="size-8" /></div>
                </div>
            </div>

            {# Dépannages #}
            <div class="card overflow-hidden">
                <div class="flex items-center justify-between px-6 py-4 border-b border-border">
                    <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Dépannages effectués</h2>
                    <span class="text-xs text-muted-foreground">{{ nbDepannages }}</span>
                </div>
                <div {{ react_component('Collection/DepannagesCollectionTable', {
                    depannages: depannages,
                    meta: depannagesMeta,
                    queryParams: depannagesParams,
                    urlPrefix: 'd'
                }) }}>
                    <div class="flex items-center justify-center gap-6"><twig:Spinner class="size-8" /></div>
                </div>
            </div>
        </div>

        {# Sidebar #}
        <div class="space-y-4">
            {% if personnel.image is defined and personnel.image %}
            <div class="card p-3">
                <img src="{{ api_url ~ '/media' ~ personnel.image.contentUrl ~ '?w=400&h=400&fm=jpg&fit=crop' }}" alt="{{ personnel.prenom }} {{ personnel.nom }}" class="w-full h-auto object-cover rounded-md" />
            </div>
            {% endif %}

            <div class="card p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Activité</h2>
                {% if nbAffectations > 0 %}
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <span class="flex items-center gap-2 text-xs text-muted-foreground"><span class="w-2.5 h-2.5 rounded-full bg-blue-500 shrink-0"></span>Voyages</span>
                        <span class="font-semibold tabular-nums text-blue-600 dark:text-blue-400">{{ nbVoyages }}</span>
                    </div>
                    <div class="flex items-center justify-between">
                        <span class="flex items-center gap-2 text-xs text-muted-foreground"><span class="w-2.5 h-2.5 rounded-full bg-orange-500 shrink-0"></span>Dépannages</span>
                        <span class="font-semibold tabular-nums text-orange-600 dark:text-orange-400">{{ nbDepannages }}</span>
                    </div>
                </div>
                {% else %}
                <p class="text-xs text-muted-foreground">Aucune activité enregistrée</p>
                {% endif %}
            </div>

            {% if is_granted('PERSONNEL_MODIFIER') %}
            <div class="card p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Actions</h2>
                <a href="{{ path('personnel.edit', { id: personnel.id }) }}" class="btn btn-secondary w-full justify-center">Modifier</a>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
