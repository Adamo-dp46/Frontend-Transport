{% extends 'base.html.twig' %}

{% block title %}Voir l'entreprise - {{ entreprise.libelle }}{% endblock %}

{% block body %}
<div class="flex items-center justify-between mb-6">
    <div class="flex items-center gap-3">
        {% if is_granted('ROLE_SUPER_ADMIN') %}
        <a href="{{ path('admin.entreprise.index') }}" class="btn-icon">
            <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
                <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
            </svg>
        </a>
        {% endif %}
        <div>
            <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">{{ entreprise.libelle }}</h1>
            <p class="text-muted-foreground text-sm mt-0.5 flex items-center gap-2">
                {% if entreprise.sigle %}
                    <span class="font-mono font-bold">{{ entreprise.sigle }}</span>
                    <span class="text-muted-foreground/40">·</span>
                {% endif %}
                {% if entreprise.type %}
                    <span>{{ entreprise.type }}</span>
                {% endif %}
                <span class="text-muted-foreground/40">·</span>
                <span>Depuis le {{ entreprise.createdAt ? entreprise.createdAt|date('d/m/Y') : '—' }}</span>
            </p>
        </div>
    </div>

    {% if is_granted('ENTREPRISE_MODIFIER') %}
    <a href="{{ path('admin.entreprise.edit', { id: entreprise.id }) }}"
       class="inline-flex items-center gap-1.5 rounded-md border px-3 py-1.5 text-sm font-medium hover:bg-accent transition-colors">
        ✏️ Modifier
    </a>
    {% endif %}
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    {# ── Colonne principale ───────────────────────────────────────────────── #}
    <div class="lg:col-span-2 space-y-4">

        {# Informations générales #}
        <div class="rounded-xl border bg-card shadow-sm p-6">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">
                Informations générales
            </h2>
            <dl class="text-sm divide-y">
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Raison sociale</dt>
                    <dd class="font-semibold">{{ entreprise.libelle }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Sigle</dt>
                    <dd class="font-mono font-bold">{{ entreprise.sigle ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Type</dt>
                    <dd>{{ entreprise.type ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Adresse</dt>
                    <dd>{{ entreprise.adresse ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Email</dt>
                    <dd>
                        {% if entreprise.email %}
                            <a href="mailto:{{ entreprise.email }}" class="text-primary hover:underline">
                                {{ entreprise.email }}
                            </a>
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Contact 1</dt>
                    <dd>
                        {% if entreprise.contact1 %}
                            <a href="tel:{{ entreprise.contact1 }}" class="text-primary hover:underline">
                                {{ entreprise.contact1 }}
                            </a>
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Contact 2</dt>
                    <dd>
                        {% if entreprise.contact2 %}
                            <a href="tel:{{ entreprise.contact2 }}" class="text-primary hover:underline">
                                {{ entreprise.contact2 }}
                            </a>
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
            </dl>
        </div>

        {# Informations légales & fiscales #}
        <div class="rounded-xl border bg-card shadow-sm p-6">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">
                Informations légales & fiscales
            </h2>
            <dl class="text-sm divide-y">
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">RCCM</dt>
                    <dd class="font-mono">{{ entreprise.rccm ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Banque</dt>
                    <dd>{{ entreprise.banque ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Centre d'impôt</dt>
                    <dd>{{ entreprise.centreimpot ?? '—' }}</dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Taux TVA</dt>
                    <dd class="font-semibold tabular-nums">
                        {% if entreprise.tauxtva is not null %}
                            {{ entreprise.tauxtva }} %
                        {% else %}
                            —
                        {% endif %}
                    </dd>
                </div>
                <div class="flex justify-between items-center py-2.5">
                    <dt class="text-muted-foreground">Enregistrée le</dt>
                    <dd class="text-xs text-muted-foreground">
                        {{ entreprise.createdAt ? entreprise.createdAt|date('d/m/Y à H:i') : '—' }}
                    </dd>
                </div>
            </dl>
        </div>

    </div>

    {# ── Panneau latéral ──────────────────────────────────────────────────── #}
    <div class="space-y-4">

        {# Carte identité rapide #}
        <div class="rounded-xl border bg-card shadow-sm p-5 space-y-3">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Identité</h2>

            <div class="flex items-center justify-center py-4">
                <div class="w-20 h-20 rounded-2xl bg-primary/10 flex items-center justify-center">
                    {% if entreprise.image is defined and entreprise.image %}
                    <div>
                        <img src="{{ api_url ~ '/media' ~ entreprise.image.contentUrl ~ '?w=400&h=400&fm=jpg&fit=crop' }}" alt="Photo actuelle" class="object-cover rounded-md" />
                    </div>
                    {% else %}
                        <span class="text-2xl font-black text-primary">
                            {{ entreprise.sigle ? entreprise.sigle|upper|slice(0,2) : entreprise.libelle|upper|slice(0,2) }}
                        </span>
                    {% endif %}
                </div>
            </div>

            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-muted-foreground text-xs">Sigle</span>
                    <span class="font-mono font-bold">{{ entreprise.sigle ?? '—' }}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-muted-foreground text-xs">Type</span>
                    <span>{{ entreprise.type ?? '—' }}</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-muted-foreground text-xs">TVA</span>
                    <span class="tabular-nums font-semibold">{{ entreprise.tauxtva ?? 0 }} %</span>
                </div>
            </div>
        </div>

        {# Contacts rapides #}
        <div class="rounded-xl border bg-card shadow-sm p-5 space-y-3">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">Contacts rapides</h2>
            <div class="space-y-2">
                {% if entreprise.email %}
                <a href="mailto:{{ entreprise.email }}"
                   class="flex items-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-accent transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted-foreground shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    <span class="truncate text-xs">{{ entreprise.email }}</span>
                </a>
                {% endif %}
                {% if entreprise.contact1 %}
                <a href="tel:{{ entreprise.contact1 }}"
                   class="flex items-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-accent transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted-foreground shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span class="text-xs">{{ entreprise.contact1 }}</span>
                </a>
                {% endif %}
                {% if entreprise.contact2 %}
                <a href="tel:{{ entreprise.contact2 }}"
                   class="flex items-center gap-2 rounded-md border px-3 py-2 text-sm hover:bg-accent transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-muted-foreground shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    <span class="text-xs">{{ entreprise.contact2 }}</span>
                </a>
                {% endif %}
                {% set statutCfg = entreprise.statut == 'ACTIF'
                    ? ['Active', 'bg-green-100 text-green-800']
                    : ['Suspendue', 'bg-red-100 text-red-800']
                %}
                {% set statut = entreprise.statut == 'ACTIF' ? 'Désactiver' : 'Réactiver' %}
                <form method="post" action="{{ path('admin.entreprise.desactiver', { id: entreprise.id }) }}" class="inline" onsubmit="return confirm('{{ statut }} cette entreprise ?')">
                    <button type="submit" class="btn {{ entreprise.statut == 'ACTIF' ? 'btn-warning' : 'btn-success' }}">
                        {{ entreprise.statut == 'ACTIF' ? 'Désactiver l\'entreprise' : 'Réactiver l\'entreprise' }}
                    </button>
                </form>
            </div>
        </div>

        {# Actions #}
        {% if is_granted('ENTREPRISE_MODIFIER') %}
        <div class="rounded-xl border bg-card shadow-sm p-5 space-y-2">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-3">Actions</h2>
            <a href="{{ path('admin.entreprise.edit', { id: entreprise.id }) }}"
               class="flex w-full items-center justify-center gap-1.5 rounded-md border px-3 py-2 text-sm font-medium hover:bg-accent transition-colors">
                ✏️ Modifier l'entreprise
            </a>
        </div>
        {% endif %}

    </div>

</div>
{% endblock %}