{% extends 'app-base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
<div class="flex min-h-svh w-full items-center justify-center p-6 md:p-10">
    <div class="w-full max-w-md">
        <div class="flex flex-col items-center text-center mb-6">
            <div class="flex size-14 items-center justify-center rounded-2xl bg-primary/10 text-primary mb-4 ring-1 ring-primary/20">
                <svg class="size-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"/>
                    <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
            </div>
            <h1 class="text-2xl font-bold tracking-tight">Mot de passe oublié ?</h1>
            <p class="text-sm text-muted-foreground mt-1.5 max-w-sm">
                Saisissez l'adresse email associée à votre compte. Nous vous enverrons un lien pour réinitialiser votre mot de passe.
            </p>
        </div>

        <twig:Card class="shadow-sm">
            <twig:Card:Content class="pt-6">
                {{ form_start(form) }}
                    <div class="grid gap-2 mb-4">
                        <twig:Label for="{{ form.email.vars.id }}">Adresse email</twig:Label>
                        <twig:Input
                            type="email"
                            id="{{ form.email.vars.id }}"
                            name="{{ form.email.vars.full_name }}"
                            value="{{ form.email.vars.value }}"
                            placeholder="m@example.com"
                            autocomplete="email"
                            required
                            autofocus
                        />
                        {{ form_errors(form.email) }}
                    </div>
                    {{ form_rest(form) }}
                    <twig:Button type="submit" class="w-full">
                        Envoyer le lien
                    </twig:Button>
                {{ form_end(form) }}
            </twig:Card:Content>
        </twig:Card>

        <div class="mt-6 text-center text-sm text-muted-foreground">
            <a href="{{ path('app_login') }}" class="inline-flex items-center gap-1.5 hover:text-foreground transition-colors">
                <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
                </svg>
                Retour à la connexion
            </a>
        </div>
    </div>
</div>
{% endblock %}
