{% extends 'base.html.twig' %}

{% block title %}Modifier l'approvisionnement{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('approvisionnement.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Modifier l'approvisionnement</h1>
    </div>
</div>

<form action="{{ path('approvisionnement.edit', { id: approvisionnement.id }) }}" method="post">
    <div class="rounded-xl border bg-card shadow-sm p-4 mb-3">
        {#
            <select name="fournisseur" required class="input">
                <option value="">-- Sélectionner un fournisseur --</option>
                {% for f in fournisseurs %}
                    <option value="{{ f.id }}" {{ approvisionnement.fournisseur.id is defined and approvisionnement.fournisseur.id == f.id ? 'selected' : '' }}>
                        {{ f.libelle }}
                    </option>
                {% endfor %}
            </select>
        #}
        <select
            name="fournisseur"
            required
            data-remote-select="fournisseurs"
            data-value="{{ approvisionnement.fournisseur.id }}"
            data-label="{{ approvisionnement.fournisseur.nom }}"
            placeholder="-- Rechercher un fournisseur --"
        ></select>
    </div>

    <div class="rounded-xl border bg-card shadow-sm p-4 mb-3">
        <div class="flex items-center justify-between px-6 py-4 border-b">
            <h2 class="text-2xl font-light">Pièces approvisionnées</h2>
            <button type="button" id="btn-add-ligne" class="btn btn-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                </svg>
                Ajouter une ligne
            </button>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm" id="table-details">
                <thead>
                    <tr class="border-b bg-muted/40">
                        <th class="text-left px-4 py-3 font-semibold">Pièce</th>
                        <th class="text-left px-4 py-3 font-semibold w-32">Quantité</th>
                        <th class="text-left px-4 py-3 font-semibold w-40">Prix unitaire (FCFA)</th>
                        <th class="text-left px-4 py-3 font-semibold w-40">Total</th>
                        <th class="w-12"></th>
                    </tr>
                </thead>
                <tbody id="tbody-details">
                    {#
                        Pré-remplissage des lignes existantes.
                        appro.details = tableau de { piece: {id, libelle, prixunitaire}, quantite, prixunitaire }
                    #}
                    {% for detail in approvisionnement.detailapprovisionnements ?? [] %}
                    <tr class="detail-ligne border-b" data-index="{{ loop.index0 }}">
                        <td class="px-4 py-3">
                            <select name="detail_piece[]" class="piece-select input" required>
                                <option value="">-- Pièce --</option>
                                {% for p in pieces %}
                                <option value="{{ p.id }}" data-prix="{{ p.prixunitaire }}" {{ detail.piece.id is defined and detail.piece.id == p.id ? 'selected' : '' }}>
                                    {{ p.libelle }}
                                </option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="detail_quantite[]" min="1" value="{{ detail.quantite ?? 1 }}" class="quantite-input input" required />
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="detail_prixunitaire[]" min="0" value="{{ detail.prixunitaire ?? 0 }}" class="prix-input input" required />
                        </td>
                        <td class="px-4 py-3">
                            <span class="total-ligne font-semibold tabular-nums text-muted-foreground">
                                {{ ((detail.quantite ?? 0) * (detail.prixunitaire ?? 0))|number_format(0, ',', ' ') }} FCFA
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <button type="button" class="btn-remove-ligne btn btn-danger" title="Supprimer la ligne">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </td>
                    </tr>
                    {% else %}
                    {# Fallback : une ligne vide si l'appro n'a pas de détails (ne devrait pas arriver) #}
                    <tr class="detail-ligne border-b" data-index="0">
                        <td class="px-4 py-3">
                            <select name="detail_piece[]" class="piece-select input" required>
                                <option value="">-- Pièce --</option>
                                {% for p in pieces %}
                                <option value="{{ p.id }}" data-prix="{{ p.prixunitaire }}">{{ p.libelle }}</option>
                                {% endfor %}
                            </select>
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="detail_quantite[]" min="1" value="1" class="quantite-input input" required />
                        </td>
                        <td class="px-4 py-3">
                            <input type="number" name="detail_prixunitaire[]" min="0" value="0" class="prix-input input" required />
                        </td>
                        <td class="px-4 py-3">
                            <span class="total-ligne font-semibold tabular-nums text-muted-foreground">0 FCFA</span>
                        </td>
                        <td class="px-4 py-3">
                            <button type="button" class="btn-remove-ligne btn btn-danger">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                </svg>
                            </button>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="border-t bg-muted/20">
                        <td colspan="3" class="px-4 py-3 text-sm font-semibold text-right">Total général :</td>
                        <td class="px-4 py-3 font-bold tabular-nums" id="total-general">0 FCFA</td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    <div class="flex items-center justify-end gap-3">
        <a href="{{ path('approvisionnement.index') }}" class="btn btn-secondary">Annuler</a>
        <button class="btn btn-primary">
            Modifier
        </button>
    </div>
</form>

{# Template pour les nouvelles lignes ajoutées dynamiquement #}
<template id="template-ligne">
    <tr class="detail-ligne border-b">
        <td class="px-4 py-3">
            <select name="detail_piece[]" class="piece-select input" required>
                <option value="">-- Pièce --</option>
                {% for p in pieces %}
                <option value="{{ p.id }}" data-prix="{{ p.prixunitaire }}">{{ p.libelle }}</option>
                {% endfor %}
            </select>
        </td>
        <td class="px-4 py-3">
            <input type="number" name="detail_quantite[]" min="1" value="1" class="quantite-input input" required />
        </td>
        <td class="px-4 py-3">
            <input type="number" name="detail_prixunitaire[]" min="0" value="0" class="prix-input input" required />
        </td>
        <td class="px-4 py-3">
            <span class="total-ligne font-semibold tabular-nums text-muted-foreground">0 FCFA</span>
        </td>
        <td class="px-4 py-3">
            <button type="button" class="btn-remove-ligne btn btn-danger">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </td>
    </tr>
</template>

<script>
(function () {
    const tbody   = document.getElementById('tbody-details')
    const template = document.getElementById('template-ligne')
    const btnAdd  = document.getElementById('btn-add-ligne')
    const totalGen = document.getElementById('total-general')

    function formatFCFA(n) {
        return n.toLocaleString('fr-FR') + ' FCFA'
    }

    function updateTotaux() {
        let grandTotal = 0
        tbody.querySelectorAll('.detail-ligne').forEach(function(row) {
            const qte   = parseFloat(row.querySelector('.quantite-input').value)  || 0
            const prix  = parseFloat(row.querySelector('.prix-input').value)       || 0
            const total = qte * prix
            grandTotal += total
            row.querySelector('.total-ligne').textContent = formatFCFA(total)
        })
        totalGen.textContent = formatFCFA(grandTotal)
    }

    function bindRow(row) {
        row.querySelector('.piece-select').addEventListener('change', function() {
            const opt = this.options[this.selectedIndex]
            const prix = opt.dataset.prix
            if (prix) row.querySelector('.prix-input').value = prix
            updateTotaux()
        })
        row.querySelector('.quantite-input').addEventListener('input', updateTotaux)
        row.querySelector('.prix-input').addEventListener('input', updateTotaux)
        row.querySelector('.btn-remove-ligne').addEventListener('click', function() {
            if (tbody.querySelectorAll('.detail-ligne').length > 1) {
                row.remove()
                updateTotaux()
            }
        })
    }

    // Binder toutes les lignes existantes (pré-remplies depuis Twig)
    tbody.querySelectorAll('.detail-ligne').forEach(bindRow)

    // Calculer les totaux au chargement
    updateTotaux()

    // Ajouter une ligne vide
    btnAdd.addEventListener('click', function() {
        const clone = template.content.cloneNode(true)
        const row   = clone.querySelector('tr')
        tbody.appendChild(row)
        bindRow(row)
        updateTotaux()
    })
})()
</script>
{% endblock %}