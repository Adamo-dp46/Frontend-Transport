{% extends 'base.html.twig' %}

{% block title %}Modifier - {{ piece.libelle }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('piece.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Modifier - <strong>{{ piece.libelle }}</strong></h1>
    </div>
</div>

<div class="card p-6">
    {{ form_start(form, { attr: { enctype: 'multipart/form-data'} }) }}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-3">
            <div class="md:col-span-2">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                    <div>{{ form_row(form.libelle) }}</div>
                    <div>{{ form_row(form.prixunitaire) }}</div>
                    <div>{{ form_row(form.typepiece) }}</div>
                    <div>{{ form_row(form.marquepiece) }}</div>
                    <div>{{ form_row(form.model) }}</div>
                </div>
            </div>
            <div class="flex flex-col gap-4">
                <div>{{ form_row(form.imageFile) }}</div>
                {% if piece.image is defined and piece.image %}
                <div>
                    <img src="{{ api_url ~ '/media' ~ piece.image.contentUrl ~ '?w=320&h=240&fm=jpg&fit=crop' }}" alt="" width="100%" height="auto" class="object-cover rounded" />
                </div>
                {% endif %}
            </div>
        </div>
        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('piece.index') }}" class="btn btn-secondary">Annuler</a>
            <button class="btn btn-primary">
                Modifier
            </button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
