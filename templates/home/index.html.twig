{% extends 'base.html.twig' %}

{% block title %}Acceuil{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col mb-6">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Tableau de bord</h1>
    </div>
    <form method="get" action="{{ path('home') }}" class="flex items-center gap-2 shrink-0 max-sm:w-full">
        <input type="date" name="debut" value="{{ debut }}" class="input input-sm" />
        <span class="text-muted-foreground text-sm">→</span>
        <input type="date" name="fin" value="{{ fin }}" class="input input-sm" />
        <button type="submit" class="btn btn-primary btn-sm">
            Filtrer
        </button>
    </form>
</div>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Exploitation</h2>

    {# KPI cards #}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Total voyages</p>
            <p class="text-2xl font-semibold">{{ exploitation.totalVoyages }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Taux de remplissage</p>
            <p class="text-2xl font-semibold">{{ exploitation.tauxRemplissage.moyenneGlobale }}%</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Voyages terminés</p>
            <p class="text-2xl font-semibold">
                {% for s in exploitation.voyagesParStatut %}
                    {% if s.statut == 'TERMINE' %}{{ s.total }}{% endif %}
                {% endfor %}
            </p>
        </div>
    </div>

    {# Graphiques #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        {# Voyages par période — barres #}
        <div class="card p-4 md:col-span-2">
            <p class="text-sm font-medium mb-3">Voyages par jour</p>
            <canvas id="chartVoyagesPeriode" height="120" data-values="{{ exploitation.voyagesParPeriode | map(v => {label: v.label, total: v.total}) | json_encode }}"></canvas>
        </div>

        {# Voyages par statut — doughnut #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Répartition par statut</p>
            <canvas id="chartStatuts" height="120" data-values="{{ exploitation.voyagesParStatut | map(s => {statut: s.statut, total: s.total}) | json_encode }}"></canvas>
        </div>

        {# Taux de remplissage par voyage — ligne #}
        <div class="card p-4 md:col-span-3">
            <p class="text-sm font-medium mb-3">Taux de remplissage par voyage</p>
            <canvas id="chartTauxVoyages" height="120" data-values="{{ exploitation.tauxRemplissage.detailParVoyage | map(v => {label: v.codeVoyage, taux: v.taux}) | json_encode }}"></canvas>
        </div>

    </div>
</section>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Financier</h2>

    {# KPI cards #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Recettes totales</p>
            <p class="text-2xl font-semibold">{{ financiere.recettesTotales | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Coût dépannages</p>
            <p class="text-2xl font-semibold">{{ financiere.coutDepannages | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Coût approvisionnements</p>
            <p class="text-2xl font-semibold">{{ financiere.coutApprovisionnements | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Bénéfice net</p>
            <p class="text-2xl font-semibold {{ financiere.beneficeNet < 0 ? 'text-red-500' : 'text-green-600' }}">
                {{ financiere.beneficeNet | number_format(0, ',', ' ') }} FCFA
            </p>
        </div>
    </div>

    {# Détail recettes #}
    <div class="grid grid-cols-3 gap-3 mb-6">
        <div class="card p-3">
            <p class="text-xs text-muted-foreground mb-1">Billetterie</p>
            <p class="text-lg font-semibold">{{ financiere.recettesTickets | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-3">
            <p class="text-xs text-muted-foreground mb-1">Courriers</p>
            <p class="text-lg font-semibold">{{ financiere.recettesCourriers | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-3">
            <p class="text-xs text-muted-foreground mb-1">Bagages</p>
            <p class="text-lg font-semibold">{{ financiere.recettesBagages | number_format(0, ',', ' ') }} FCFA</p>
        </div>
    </div>

    {# Graphiques #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Recettes par jour</p>
            <canvas id="chartRecettes" height="120"
                data-values="{{ financiere.recettesParJour | map(r => {label: r.label, montant: r.montant}) | json_encode }}">
            </canvas>
        </div>

        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Coûts par jour</p>
            <canvas id="chartCouts" height="120"
                data-values="{{ financiere.coutsParJour | map(c => {label: c.label, depannage: c.depannage, approvisionnement: c.approvisionnement}) | json_encode }}">
            </canvas>
        </div>

    </div>
</section>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Stock</h2>
    {# KPI cards #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Total pièces</p>
            <p class="text-2xl font-semibold">{{ stock.totalPieces }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Pièces critiques</p>
            <p class="text-2xl font-semibold {{ stock.piecesCritiques > 0 ? 'text-red-500' : '' }}">
                {{ stock.piecesCritiques }}
            </p>
        </div>
    </div>

    {# Graphiques #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {# Stock par pièce — barres horizontales #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Stock actuel par pièce</p>
            <canvas id="chartStockPieces" height="160"
                data-values="{{ stock.stockParPiece | map(p => {libelle: p.libelle, stockactuel: p.stockactuel, seuilstock: p.seuilstock, critique: p.critique}) | json_encode }}">
            </canvas>
        </div>

        {# Mouvements récents — tableau simple #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Mouvements récents</p>
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-muted-foreground border-b">
                        <th class="pb-2 font-medium">Pièce</th>
                        <th class="pb-2 font-medium">Type</th>
                        <th class="pb-2 font-medium text-right">Qté</th>
                        <th class="pb-2 font-medium text-right">Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% for m in stock.mouvementsRecents %}
                    <tr class="border-b last:border-0">
                        <td class="py-2">{{ m.piece }}</td>
                        <td class="py-2">
                            <span class="text-xs px-2 py-0.5 rounded-full
                                {% if m.typemouvement == 'ENTREE' %}bg-green-100 text-green-700
                                {% elseif m.typemouvement == 'SORTIE' %}bg-red-100 text-red-700
                                {% else %}bg-yellow-100 text-yellow-700{% endif %}">
                                {{ m.typemouvement }}
                            </span>
                        </td>
                        <td class="py-2 text-right">{{ m.quantite }}</td>
                        <td class="py-2 text-right text-muted-foreground">{{ m.date }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Flotte</h2>
    {# KPI #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Total véhicules</p>
            <p class="text-2xl font-semibold">{{ flotte.totalVehicules }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        {# Véhicules par état — doughnut #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Véhicules par état</p>
            <canvas id="chartVehiculesEtat" height="160"
                data-values="{{ flotte.vehiculesParEtat | map(v => {etat: v.etat, total: v.total}) | json_encode }}">
            </canvas>
        </div>

        {# Véhicules les plus en panne — barres horizontales #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Véhicules les plus en panne</p>
            <canvas id="chartVehiculesDepannage" height="160"
                data-values="{{ flotte.vehiculesParDepannage | map(v => {matricule: v.matricule, nbrdepannages: v.nbrdepannages}) | json_encode }}">
            </canvas>
        </div>

        {# Coût maintenance par véhicule — barres horizontales #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Coût maintenance par véhicule</p>
            <canvas id="chartCoutMaintenance" height="160"
                data-values="{{ flotte.coutMaintenanceParVehicule | map(v => {matricule: v.matricule, couttotal: v.couttotal}) | json_encode }}">
            </canvas>
        </div>

    </div>
</section>

{% endblock %}