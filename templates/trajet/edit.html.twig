{% extends 'base.html.twig' %}

{% block title %}Modifier le trajet #{{ trajet.codetrajet }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('trajet.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Modifier le trajet #{{ trajet.id }}</h1>
    </div>
</div>

<div class="rounded-xl border bg-card shadow-sm p-6">
    {{ form_start(form) }}
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mb-3">
            {#
                <div>{{ form_row(form.provenance) }}</div>
                <div>{{ form_row(form.destination) }}</div>
            #}
        </div>
        <div class="mb-3">{{ form_row(form.tarifId) }}</div>
        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('trajet.index') }}" class="btn btn-secondary">Annuler</a>
            <button class="btn btn-primary">
                Modifier
            </button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}