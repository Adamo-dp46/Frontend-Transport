{% extends 'base.html.twig' %}
{% block title %}Changer mon mot de passe{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('profile.index') }}" class="btn-icon" aria-label="Retour">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <div>
            <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Changer mon mot de passe</h1>
            <p class="text-muted-foreground text-sm mt-0.5">Choisissez un mot de passe sécurisé d'au moins 8 caractères</p>
        </div>
    </div>

    {% if error %}
    <div class="mb-4 flex items-start gap-2 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <span>{{ error }}</span>
    </div>
    {% endif %}

    <div class="grid gap-6 md:grid-cols-3">

        {# ── Formulaire ── #}
        <div class="md:col-span-2">
            <div class="rounded-xl border bg-card shadow-sm overflow-hidden">
                <div class="flex items-center gap-3 px-6 py-4 border-b bg-muted/30">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary/10 text-primary">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="font-semibold leading-tight">Mot de passe</h2>
                        <p class="text-xs text-muted-foreground">Il vous sera demandé à la prochaine connexion.</p>
                    </div>
                </div>

                <form method="POST" action="{{ path('profile.password') }}" class="p-6 space-y-5" id="form-password">

                    <div class="field">
                        <label for="currentPassword" class="label">Mot de passe actuel <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input type="password" name="currentPassword" id="currentPassword" required placeholder="••••••••"
                                   autocomplete="current-password" class="input pr-10"/>
                            <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="currentPassword" aria-label="Afficher / masquer">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="field">
                        <label for="newPassword" class="label">Nouveau mot de passe <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input type="password" name="newPassword" id="newPassword" required placeholder="••••••••" minlength="4"
                                   autocomplete="new-password" class="input pr-10" oninput="checkStrength(this.value)"/>
                            <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="newPassword" aria-label="Afficher / masquer">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </button>
                        </div>
                        <div class="space-y-1 mt-2">
                            <div class="flex gap-1">
                                <div id="bar-1" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                                <div id="bar-2" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                                <div id="bar-3" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                                <div id="bar-4" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                            </div>
                            <p id="strength-label" class="text-xs text-muted-foreground"></p>
                        </div>
                    </div>

                    <div class="field">
                        <label for="confirmPassword" class="label">Confirmer le nouveau mot de passe <span class="text-red-500">*</span></label>
                        <div class="relative">
                            <input type="password" name="confirmPassword" id="confirmPassword" required placeholder="••••••••"
                                   autocomplete="new-password" class="input pr-10" oninput="checkConfirm()"/>
                            <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="confirmPassword" aria-label="Afficher / masquer">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </button>
                        </div>
                        <p id="confirm-hint" class="text-xs hidden mt-1"></p>
                    </div>

                    <div class="flex items-center justify-end gap-3 pt-2 border-t">
                        <a href="{{ path('profile.index') }}" class="btn btn-secondary">Annuler</a>
                        <button type="submit" class="btn btn-primary">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                            </svg>
                            Mettre à jour
                        </button>
                    </div>
                </form>
            </div>
        </div>

        {# ── Conseils ── #}
        <aside class="rounded-xl border bg-card shadow-sm p-5 h-fit">
            <h2 class="text-xs font-semibold uppercase tracking-wide text-muted-foreground mb-3">Conseils</h2>
            <ul class="space-y-2.5 text-sm text-muted-foreground">
                <li class="flex items-start gap-2"><span class="text-primary mt-0.5">•</span> Au moins 4 caractères</li>
                <li class="flex items-start gap-2"><span class="text-primary mt-0.5">•</span> Mélangez majuscules et minuscules</li>
                <li class="flex items-start gap-2"><span class="text-primary mt-0.5">•</span> Ajoutez chiffres et caractères spéciaux</li>
                <li class="flex items-start gap-2"><span class="text-primary mt-0.5">•</span> Évitez un mot de passe déjà utilisé ailleurs</li>
            </ul>
        </aside>
    </div>
</div>

<script>
document.querySelectorAll('.btn-toggle-pwd').forEach(btn => {
    btn.addEventListener('click', function () {
        const input = document.getElementById(this.dataset.target)
        input.type = input.type === 'password' ? 'text' : 'password'
    })
})

function checkStrength(value) {
    let score = 0
    if (value.length >= 8)          score++
    if (/[A-Z]/.test(value))        score++
    if (/[0-9]/.test(value))        score++
    if (/[^A-Za-z0-9]/.test(value)) score++

    const bars   = [1,2,3,4].map(i => document.getElementById('bar-' + i))
    const label  = document.getElementById('strength-label')
    const colors = ['bg-red-500', 'bg-orange-400', 'bg-yellow-400', 'bg-green-500']
    const labels = ['Très faible', 'Faible', 'Moyen', 'Fort']

    bars.forEach((bar, i) => {
        bar.className = 'h-1 flex-1 rounded-full transition-colors ' + (i < score ? colors[score - 1] : 'bg-muted')
    })

    label.textContent = value.length > 0 ? labels[score - 1] ?? '' : ''
    label.className   = 'text-xs ' + (score <= 1 ? 'text-red-500' : score <= 2 ? 'text-orange-500' : score === 3 ? 'text-yellow-600' : 'text-green-600')
}

function checkConfirm() {
    const newPwd     = document.getElementById('newPassword').value
    const confirmPwd = document.getElementById('confirmPassword').value
    const hint       = document.getElementById('confirm-hint')

    if (!confirmPwd) { hint.classList.add('hidden'); return }

    if (newPwd === confirmPwd) {
        hint.textContent = '✓ Les mots de passe correspondent'
        hint.className   = 'text-xs text-green-600 mt-1'
    } else {
        hint.textContent = '✗ Les mots de passe ne correspondent pas'
        hint.className   = 'text-xs text-red-600 mt-1'
    }
}
</script>
{% endblock %}
