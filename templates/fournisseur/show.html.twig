{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}Fournisseur - {{ fournisseur.libelle }}{% endblock %}

{% block body %}
<div class="max-w-[1100px] mx-auto">

    {# En-tête #}
    <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
        <div class="min-w-0">
            <a href="{{ path('fournisseur.index') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-2">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                Retour aux fournisseurs
            </a>
            <p class="text-xs uppercase tracking-wide text-muted-foreground mb-0.5">Fournisseur</p>
            <h1 class="text-3xl font-light tracking-[-0.5px] leading-[1.2] break-words">{{ fournisseur.libelle }}</h1>
            <p class="text-sm text-muted-foreground mt-1">#{{ fournisseur.id }} · Créé le {{ fournisseur.createdAt|date('d/m/Y à H:i') }}</p>
        </div>
        <div class="flex items-center gap-2 flex-wrap shrink-0">
            <a href="{{ path('fournisseur.edit', {id: fournisseur.id}) }}" class="btn btn-primary">
                <svg class="nav-item-icon" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#edit"></use></svg>
                Modifier
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 space-y-4">
            {# Informations #}
            <div class="card p-6">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">Informations générales</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
                    {{ ui.field('Libellé', fournisseur.libelle) }}
                    {{ ui.field('Nom', fournisseur.nom) }}
                    {{ ui.field('Téléphone', fournisseur.contact ? '<a href="tel:' ~ fournisseur.contact ~ '" class="text-primary hover:underline">' ~ fournisseur.contact ~ '</a>' : null, false, true) }}
                    {{ ui.field('Email', fournisseur.email ? '<a href="mailto:' ~ fournisseur.email ~ '" class="text-primary hover:underline">' ~ fournisseur.email ~ '</a>' : null, false, true) }}
                    {{ ui.field('Adresse', fournisseur.adresse) }}
                    {{ ui.field('Pays', fournisseur.pays) }}
                </div>
            </div>

            {# Approvisionnements liés #}
            <div {{ react_component('Collection/FournisseurApprovisionnementTable', {
                    approvisionnements: approvisionnements,
                    meta: meta,
                    queryParams: queryParams
                }) }} class="mt-3"
            >
                <div class="flex items-center justify-center gap-6">
                    <twig:Spinner class="size-8" />
                </div>
            </div>
        </div>

        {# Sidebar #}
        <div class="space-y-4">
            <div class="card p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Statistiques</h2>
                <div class="text-center py-2">
                    <p class="text-4xl font-semibold tabular-nums text-primary">{{ fournisseur.approvisionnementsCount }}</p>
                    <p class="text-xs text-muted-foreground mt-1">approvisionnement(s) au total</p>
                </div>
                {% if fournisseur.approvisionnementsCount > 0 %}
                <div class="space-y-2 pt-3 mt-1 border-t border-border text-sm">
                    <div class="flex justify-between">
                        <span class="text-muted-foreground text-xs">Premier appro.</span>
                        <span class="text-xs font-medium">{{ fournisseur.firstApprovisionnement.dateappro ? fournisseur.firstApprovisionnement.dateappro|date('d/m/Y') : '—' }}</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground text-xs">Dernier appro.</span>
                        <span class="text-xs font-medium">{{ fournisseur.lastApprovisionnement.dateappro ? fournisseur.lastApprovisionnement.dateappro|date('d/m/Y') : '—' }}</span>
                    </div>
                </div>
                {% endif %}
            </div>

            {% if is_granted('APPROVISIONNEMENT_CREER') %}
            <div class="card p-5">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Actions</h2>
                <a href="{{ path('approvisionnement.new') }}" class="btn btn-primary w-full justify-center">
                    + Nouvel approvisionnement
                </a>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
