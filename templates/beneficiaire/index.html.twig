{% extends 'base.html.twig' %}

{% block title %}Les bénéficiaires{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des bénéficiaires</h1>
        <p class="text-sm font-light text-muted-foreground mt-1">Bénéficiaires des remises sur les tickets</p>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('BENEFICIAIRE_CREER') %}
        <a href="{{ path('beneficiaire.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#new"></use></svg>
            Nouveau bénéficiaire
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Billetterie/BeneficiaireTable', {
        beneficiaires: items,
        meta: meta,
        queryParams: queryParams,
        canEdit: is_granted('BENEFICIAIRE_MODIFIER'),
        canDelete: is_granted('BENEFICIAIRE_SUPPRIMER'),
        csrfDelete: csrf_token('delete_beneficiaire')
    }) }}
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
