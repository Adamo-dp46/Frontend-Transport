<div class="card p-5 flex flex-col">
    <div class="flex items-start justify-between mb-3">
        <span class="flex size-10 items-center justify-center rounded-xl {{ tones[color] ?? tones.slate }}">
            <svg class="size-5" fill="none" stroke="currentColor" stroke-width="1.6" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="{{ icons[icon] ?? icons.chart }}" />
            </svg>
        </span>
    </div>
    <p class="text-xs text-muted-foreground">{{ label }}</p>
    <p class="text-2xl font-semibold tracking-tight mt-0.5 {{ valueClass }}">{{ value }}{% if unit %} <span class="text-sm font-normal text-muted-foreground">{{ unit }}</span>{% endif %}</p>
    {% if sub %}<p class="text-xs text-muted-foreground mt-auto pt-2">{{ sub }}</p>{% endif %}
</div>
{% endmacro %}

{# ── Carte « graphique / contenu » ───────────────────────────────── #}
{% macro chartCardOpen(title, span) %}
<div class="card p-5 {{ span }}">
    <p class="text-sm font-medium text-muted-foreground mb-4">{{ title }}</p>
{% endmacro %}

{% macro chartCardClose() %}
</div>
{% endmacro %}
