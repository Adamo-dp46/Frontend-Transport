{% extends 'base.html.twig' %}

{% block title %}La liste des types de pieces{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des type de pièces</h1>
        {# <p class="text-muted-foreground text-sm">Les type</p> #}
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('TYPEPIECE_CREER') %}
        <a href="{{ path('typepiece.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouveau type de pièce
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Stock/TypepieceTable', {
        typepieces: typepieces,
        canEdit: is_granted('TYPEPIECE_MODIFIER'),
        canDelete: is_granted('TYPEPIECE_SUPPRIMER'),
        csrfDelete: csrf_token('delete_typepiece')
    }) }} class="mb-3"
> {#
    - On a utiliser le csrf de manière globale mais on peut aussi..
        typepieces: typepieces|map(tp => {
            id: tp.id,
            libelle: tp.libelle,
            csrf: csrf_token('delete_typepiece' ~ tp.id)
        }) -- Pour être plus strict et rajouté 'csrf' dans le type
#}
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}