{% extends 'base.html.twig' %}

{% block title %}Modifier un tarif{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('tarif.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">
        Modifier&nbsp;:
        {{ tarif.garedepart.libelle ?? '?' }} → {{ tarif.garearrivee.libelle ?? '?' }}
    </h1>
</div>
{% include 'tarif/_form.html.twig' with { button: 'Enregistrer' } %}
{% endblock %}
