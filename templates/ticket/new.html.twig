{% extends 'base.html.twig' %}

{% block title %}Nouveau tickets{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('ticket.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron-left"></use></svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Nouveau ticket</h1>
    </div>
</div>

<div {{ react_component('Billetterie/TicketForm', {
        voyages: voyages,
        gares: gares,
        preselectVoyageId: preselect_voyage ?? 0
    }) }}
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}