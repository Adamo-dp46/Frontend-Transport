{% extends 'base.html.twig' %}

{% block title %}La liste des véhicules{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des véhicules</h1>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('CAR_CREER') %}
        <a href="{{ path('car.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouveau véhicule
        </a>
        {% endif %}
    </div>
</div>

{# ── Compteurs par état ───────────────────────────────────────────────── #}
{% set etats = {
    'Disponible':    { label: 'Disponibles',    color: 'emerald', icon: '✓' },
    'Mission':       { label: 'En mission',     color: 'blue',    icon: '→' },
    'Maintenance':{ label: 'En maintenance', color: 'amber',   icon: '⚙' },
    'Panne':      { label: 'En panne',       color: 'red',     icon: '!' },
} %}

<div class="grid grid-cols-2 gap-3 sm:grid-cols-4 mb-6">
    {% for key, meta in etats %}
    {% set count = parEtat[key] ?? 0 %}
    <div class="card p-4 flex items-center gap-3">
        <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full
            {{ meta.color == 'emerald' ? 'bg-emerald-100 text-emerald-600' :
                meta.color == 'blue' ? 'bg-blue-100 text-blue-600' :
                meta.color == 'amber' ? 'bg-amber-100 text-amber-600' : 'bg-red-100 text-red-600' }}
            text-sm font-bold">
            {{ meta.icon }}
        </div>
        <div>
            <p class="text-2xl font-bold leading-none">{{ count }}</p>
            <p class="text-xs text-muted-foreground mt-0.5">{{ meta.label }}</p>
        </div>
    </div>
    {% endfor %}
</div>

<div {{ react_component('Flotte/CarTable', {
        cars: cars,
        canEdit: is_granted('CAR_MODIFIER'),
        canDelete: is_granted('CAR_SUPPRIMER'),
        csrfDelete: csrf_token('delete_car')
    }) }} class="mb-3"
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
