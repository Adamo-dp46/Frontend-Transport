## 6. Sizing

```html
<!-- Width -->
<div class="w-4">       <!-- 16px -->
<div class="w-full">    <!-- 100% -->
<div class="w-screen">  <!-- 100vw -->
<div class="w-1/2">     <!-- 50% -->
<div class="w-1/3">     <!-- 33% -->
<div class="w-auto">

<!-- Max/Min width -->
<div class="max-w-sm">   <!-- 384px -->
<div class="max-w-md">   <!-- 448px -->
<div class="max-w-lg">   <!-- 512px -->
<div class="max-w-xl">   <!-- 576px -->
<div class="max-w-2xl">  <!-- 672px -->
<div class="max-w-7xl">  <!-- 80rem -->

<!-- Height — même logique -->
<div class="h-4 h-full h-screen h-auto min-h-screen">
```

