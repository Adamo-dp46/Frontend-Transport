{% extends 'app-base.html.twig' %}

{% block title %}Oups, une erreur est survenue{% endblock %}

{% block body %}
<style>
  @import url('https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&display=swap');
  @import url('https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500&display=swap');

  .error-page-wrapper {
    font-family: 'Geist', ui-sans-serif, system-ui, -apple-system, sans-serif;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #ffffff;
    padding: 2rem;
  }

  .error-card {
    max-width: 420px;
    width: 100%;
    text-align: center;
  }

  .error-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid #e4e4e7;
    background-color: #fafafa;
    font-size: 0.75rem;
    font-weight: 500;
    color: #71717a;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .error-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background-color: #ef4444;
    animation: pulse-dot 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .error-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    border: 1px solid #e4e4e7;
    background-color: #fafafa;
    margin: 0 auto 1.25rem;
    color: #71717a;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 700;
    line-height: 1;
    color: #09090b;
    letter-spacing: -0.04em;
    margin-bottom: 0.75rem;
  }

  .error-divider {
    width: 2rem;
    height: 2px;
    background-color: #e4e4e7;
    margin: 0 auto 1.25rem;
    border-radius: 9999px;
  }

  .error-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #09090b;
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .error-description {
    font-size: 0.875rem;
    color: #71717a;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  /* Debug block */
  .error-debug {
    margin-bottom: 1.75rem;
    text-align: left;
  }

  .error-debug-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 0.875rem;
    background-color: #09090b;
    border-radius: 0.375rem 0.375rem 0 0;
    border: 1px solid #27272a;
  }

  .error-debug-dot {
    width: 10px;
    height: 10px;
    border-radius: 9999px;
  }

  .error-debug-label {
    font-size: 0.6875rem;
    font-family: 'Geist Mono', ui-monospace, monospace;
    color: #71717a;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-left: auto;
  }

  .error-debug pre {
    margin: 0;
    padding: 0.875rem 1rem;
    background-color: #09090b;
    border: 1px solid #27272a;
    border-top: none;
    border-radius: 0 0 0.375rem 0.375rem;
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: 0.75rem;
    color: #f87171;
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .error-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    background-color: #09090b;
    color: #fafafa;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background-color 0.15s ease;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    letter-spacing: -0.005em;
  }

  .btn-primary:hover {
    background-color: #18181b;
    color: #fafafa;
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.25rem;
    border-radius: 0.375rem;
    background-color: #ffffff;
    color: #09090b;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    border: 1px solid #e4e4e7;
    transition: background-color 0.15s ease;
    cursor: pointer;
    width: 100%;
    justify-content: center;
    letter-spacing: -0.005em;
  }

  .btn-secondary:hover {
    background-color: #f4f4f5;
    color: #09090b;
    text-decoration: none;
  }

  .error-meta {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #f4f4f5;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: #a1a1aa;
    font-family: 'Geist Mono', ui-monospace, monospace;
  }

  .error-meta-separator {
    color: #d4d4d8;
  }
</style>

<div class="error-page-wrapper">
  <div class="error-card">

    <div class="error-badge">
      <span class="error-badge-dot"></span>
      Erreur serveur
    </div>

    <div class="error-icon-wrapper">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24"
        fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20z"/>
        <path d="M12 8v4"/>
        <path d="M12 16h.01"/>
      </svg>
    </div>

    <div class="error-code">{{ status_code }}</div>

    <div class="error-divider"></div>

    <h1 class="error-title">Une erreur est survenue</h1>
    <p class="error-description">
      Une erreur inattendue s'est produite sur le serveur. Notre équipe en a été informée et travaille à la résolution.
    </p>

    {% if app.debug %}
    <div class="error-debug">
      <div class="error-debug-header">
        <span class="error-debug-dot" style="background:#ef4444;"></span>
        <span class="error-debug-dot" style="background:#f59e0b; margin-left:4px;"></span>
        <span class="error-debug-dot" style="background:#22c55e; margin-left:4px;"></span>
        <span class="error-debug-label">debug · exception</span>
      </div>
      <pre>{{ exception.message }}</pre>
    </div>
    {% endif %}

    <div class="error-actions">
      <a href="{{ path('home') }}" class="btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
          <polyline points="9 22 9 12 15 12 15 22"/>
        </svg>
        Retour à l'accueil
      </a>
      <a href="javascript:location.reload()" class="btn-secondary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24"
          fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
          <path d="M21 3v5h-5"/>
          <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
          <path d="M8 16H3v5"/>
        </svg>
        Réessayer
      </a>
    </div>

    <div class="error-meta">
      <span>HTTP {{ status_code }}</span>
      <span class="error-meta-separator">·</span>
      <span>{{ status_text }}</span>
    </div>

  </div>
</div>
{% endblock %}
