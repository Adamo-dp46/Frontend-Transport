{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - Propriétaire{% endblock %}

{% block body %}
<div class="mb-8">
    <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Espace propriétaire</h1>
    <p class="text-muted-foreground mt-2">Vue d'ensemble de votre compagnie de transport</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">

    {# Dashboard général #}
    <a href="{{ path('home') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-blue-100 text-blue-700 flex items-center justify-center text-lg">
                📊
            </div>
            <span class="text-xs text-muted-foreground">Exploitation · Financier · Stock · Flotte</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Tableau de bord</p>
        <p class="text-sm text-muted-foreground">Vue globale — voyages, recettes, stock et flotte sur la période</p>
    </a>

    {# Caisse #}
    <a href="{{ path('caisse') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-green-100 text-green-700 flex items-center justify-center text-lg">
                🧾
            </div>
            <span class="text-xs text-muted-foreground">Journalier · Par agent</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Caisse</p>
        <p class="text-sm text-muted-foreground">Résumé des encaissements par agent et par jour avec détail par voyage</p>
    </a>

    {# Billetterie #}
    <a href="{{ path('billetterie') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-purple-100 text-purple-700 flex items-center justify-center text-lg">
                🎫
            </div>
            <span class="text-xs text-muted-foreground">Tickets · Recettes · Trajets · Cars</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Billetterie</p>
        <p class="text-sm text-muted-foreground">Recettes par jour, par trajet et par véhicule sur la période</p>
    </a>

    <a href="{{ path('stats.courrier') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-blue-100 text-blue-700 flex items-center justify-center text-lg">
                📦
            </div>
            <span class="text-xs text-muted-foreground">Statuts · Recettes · Trajets</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Courriers</p>
        <p class="text-sm text-muted-foreground">Suivi des colis — recettes, statuts et trajets les plus actifs</p>
    </a>

    <a href="{{ path('stats.bagage') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center text-lg">
                🧳
            </div>
            <span class="text-xs text-muted-foreground">Statuts · Recettes · Poids</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Bagages</p>
        <p class="text-sm text-muted-foreground">Suivi des bagages — recettes, poids total et bagages perdus</p>
    </a>

    {# Agents #}
    <a href="{{ path('agent') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-amber-100 text-amber-700 flex items-center justify-center text-lg">
                👤
            </div>
            <span class="text-xs text-muted-foreground">Ventes · Classement</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Agents</p>
        <p class="text-sm text-muted-foreground">Performance des agents — tickets vendus et recettes générées</p>
    </a>

    {# Personnel #}
    <a href="{{ path('personnels') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-orange-100 text-orange-700 flex items-center justify-center text-lg">
                👷
            </div>
            <span class="text-xs text-muted-foreground">Voyages · Dépannages</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Personnel</p>
        <p class="text-sm text-muted-foreground">Affectations par employé — voyages effectués et dépannages traités</p>
    </a>

    {# Flotte #}
    <a href="{{ path('flotte') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-red-100 text-red-700 flex items-center justify-center text-lg">
                🚌
            </div>
            <span class="text-xs text-muted-foreground">Activité · Pannes · Coûts</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Flotte</p>
        <p class="text-sm text-muted-foreground">Activité des véhicules — voyages, dépannages et coûts de maintenance</p>
    </a>

    {# Trajets #}
    <a href="{{ path('trajets') }}" class="card p-6 hover:border-primary transition-colors group">
        <div class="flex items-start justify-between mb-4">
            <div class="size-10 rounded-lg bg-teal-100 text-teal-700 flex items-center justify-center text-lg">
                🗺️
            </div>
            <span class="text-xs text-muted-foreground">Utilisation · Recettes</span>
        </div>
        <p class="font-medium text-base mb-1 group-hover:text-primary transition-colors">Trajets</p>
        <p class="text-sm text-muted-foreground">Trajets les plus utilisés, recettes et nombre de tickets par ligne</p>
    </a>

</div>
{% endblock %}