{% extends 'base.html.twig' %}

{% block title %}Flotte activité{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col mb-6">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Flotte</h1>
    </div>
    <form method="get" action="{{ path('flotte') }}" class="flex items-center gap-2 shrink-0 max-sm:w-full">
        <input type="date" name="debut" value="{{ debut }}" class="input input-sm" />
        <span class="text-muted-foreground text-sm">→</span>
        <input type="date" name="fin" value="{{ fin }}" class="input input-sm" />
        <button type="submit" class="bg-blue-900 p-2 rounded-2xl">
            Filtrer
        </button>
    </form>
</div>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Activité flotte</h2>

    {# KPI #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Total véhicules</p>
            <p class="text-2xl font-semibold">{{ flotteActivite.totalVehicules }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">En mission</p>
            <p class="text-2xl font-semibold">{{ flotteActivite.vehiculesEnVoyage }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        {# Activité par véhicule — barres groupées #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Voyages et dépannages par véhicule</p>
            <canvas id="chartFlotteActivite" height="160"
                data-values="{{ flotteActivite.activiteParVehicule | map(v => {
                    matricule: v.matricule,
                    nbvoyages: v.nbvoyages,
                    nbdepannages: v.nbdepannages,
                    etat: v.etat
                }) | json_encode }}">
            </canvas>
        </div>

        {# Tableau détail #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Détail par véhicule</p>
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-muted-foreground border-b">
                        <th class="pb-2 font-medium">Matricule</th>
                        <th class="pb-2 font-medium">État</th>
                        <th class="pb-2 font-medium text-right">Voyages</th>
                        <th class="pb-2 font-medium text-right">Dépannages</th>
                    </tr>
                </thead>
                <tbody>
                    {% for v in flotteActivite.activiteParVehicule %}
                    <tr class="border-b last:border-0">
                        <td class="py-2 font-medium">{{ v.matricule }}</td>
                        <td class="py-2">
                            <span class="text-xs px-2 py-0.5 rounded-full
                                {% if v.etat == 'Disponible' %}bg-green-100 text-green-700
                                {% elseif v.etat == 'Mission' %}bg-blue-100 text-blue-700
                                {% elseif v.etat == 'Panne' %}bg-red-100 text-red-700
                                {% else %}bg-gray-100 text-gray-500{% endif %}">
                                {{ v.etat }}
                            </span>
                        </td>
                        <td class="py-2 text-right">{{ v.nbvoyages }}</td>
                        <td class="py-2 text-right">{{ v.nbdepannages }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

    </div>
</section>
{% endblock %}