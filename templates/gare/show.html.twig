{% extends 'base.html.twig' %}

{% block title %}La gare - {{ gare.libelle }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-5">
    <a href="{{ path('gare.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">
            Gare #{{ gare.id }}
        </h1>
    </div>
</div>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="card p-4">
        <p class="text-lg font-light text-muted-foreground mb-2">Chef de gare</p>
        <p class="font-semibold">{{ gare.chefgare }}</p>
    </div>
    <div class="card p-4">
        <p class="text-lg font-light text-muted-foreground mb-2">Ville</p>
        <p class="font-semibold">{{ gare.ville }}</p>
    </div>
    <div class="card p-4">
        <p class="text-lg font-light text-muted-foreground mb-2">Libellé</p>
        <p class="font-semibold">{{ gare.libelle }}</p>
    </div>
    <div class="card p-4">
        <p class="text-lg font-light text-muted-foreground mb-2">Contact 1</p>
        <p class="font-semibold">{{ gare.contact1 }}</p>
    </div>
    <div class="card p-4">
        <p class="text-lg font-light text-muted-foreground mb-2">Contact 2</p>
        <p class="font-semibold">{{ gare.contact2 }}</p>
    </div>
</div>
<div class="card p-4">
    <p class="text-lg font-light text-muted-foreground mb-2">Description</p>
    <p class="font-semibold">{{ gare.description }}</p>
</div>
{% endblock %}