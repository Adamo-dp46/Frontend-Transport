{% extends 'base.html.twig' %}

{% block title %}La liste des gares{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des gares</h1>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('GARE_CREER') %}
        <a href="{{ path('gare.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouvelle gare
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Exploitation/GareTable', {
        gares: gares,
        canEdit: is_granted('GARE_MODIFIER'),
        canDelete: is_granted('GARE_SUPPRIMER'),
        csrfDelete: csrf_token('delete_gare')
    }) }} class="mb-3"
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}