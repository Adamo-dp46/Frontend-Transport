{% extends 'base.html.twig' %}

{% block title %}Modifier - {{ beneficiaire.nom }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('beneficiaire.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron-left"></use></svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Modifier - <strong>{{ beneficiaire.nom }}</strong></h1>
    </div>
</div>

<div class="card p-6 max-w-xl">
    {{ form_start(form) }}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>{{ form_row(form.nom) }}</div>
            <div>{{ form_row(form.categorie) }}</div>
            <div class="sm:col-span-2">{{ form_row(form.contact) }}</div>
        </div>
        <div class="flex items-center justify-end gap-3 mt-6 pt-4 border-t border-border">
            <a href="{{ path('beneficiaire.index') }}" class="btn btn-secondary">Annuler</a>
            <button class="btn btn-primary">Modifier</button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}
