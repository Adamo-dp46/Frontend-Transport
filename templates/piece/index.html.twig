{% extends 'base.html.twig' %}

{% block title %}La liste des pieces{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des pièces</h1>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('PIECE_CREER') %}
        <a href="{{ path('piece.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouvelle pièce
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Stock/PieceTable', {
        pieces: items,
        meta: meta,
        queryParams: queryParams,
        typepieces: typepieces,
        marquepieces: marquepieces,
        models: models,
        apiUrl: api_url,
        canEdit: is_granted('PIECE_MODIFIER'),
        canDelete: is_granted('PIECE_SUPPRIMER'),
        csrfDelete: csrf_token('delete_piece')
    }) }} class="mb-3 mt-3"
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}