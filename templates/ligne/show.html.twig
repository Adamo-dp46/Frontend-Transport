{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}{{ ligne.libelle ?? ligne.codeligne }}{% endblock %}

{% block body %}
<div class="max-w-[1000px] mx-auto">

    {# En-tête #}
    <div class="mb-6">
        <a href="{{ path('ligne.index') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Retour aux lignes
        </a>
        <div class="flex items-center gap-2 flex-wrap mb-1">
            <p class="text-xs uppercase tracking-wide text-muted-foreground">Ligne</p>
            {{ ui.badge(ligne.codeligne, 'zinc') }}
        </div>
        <h1 class="text-2xl sm:text-3xl font-light tracking-[-0.5px] leading-[1.2] flex items-center gap-3 flex-wrap">
            <span>{{ ligne.gareorigine.libelle }}</span>
            <svg class="size-5 text-muted-foreground shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12"/></svg>
            <span>{{ ligne.gareterminus.libelle }}</span>
        </h1>
    </div>

    {# Arrêts #}
    <div class="card p-6 mb-4">
        <div class="flex items-center justify-between gap-3 mb-4">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Arrêts ({{ ligne.arrets|length }})</h2>
            {% if is_granted('TARIF_VOIR') %}
            <a href="{{ path('tarif.index') }}" class="text-xs text-primary hover:underline shrink-0">Voir la grille tarifaire</a>
            {% endif %}
        </div>
        <ol class="space-y-1">
            {% for arret in ligne.arrets|sort((a, b) => a.ordre <=> b.ordre) %}
            <li class="flex gap-3">
                <div class="flex flex-col items-center w-6 shrink-0">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-blue-50 text-xs font-semibold text-blue-600 dark:bg-blue-950 dark:text-blue-300">{{ arret.ordre }}</span>
                    {% if not loop.last %}<span class="flex-1 w-0.5 bg-border my-0.5"></span>{% endif %}
                </div>
                <div class="pb-3">
                    <p class="text-sm font-medium">{{ arret.gare.libelle }}</p>
                    {% if arret.gare.ville %}<p class="text-xs text-muted-foreground">{{ arret.gare.ville }}</p>{% endif %}
                </div>
            </li>
            {% endfor %}
        </ol>
        <p class="text-xs text-muted-foreground mt-2 pt-3 border-t border-border">Les prix sont définis dans la <strong>grille tarifaire globale</strong> (gare → gare), commune à toutes les lignes.</p>
    </div>

    {# Voyages liés #}
    <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-3">Voyages liés</h2>
    <div {{ react_component('Collection/VoyagesCollectionTable', {
        voyages: voyages,
        meta: voyagesMeta,
        queryParams: voyagesParams
    }) }}>
        <div class="flex items-center justify-center gap-6">
            <twig:Spinner class="size-8" />
        </div>
    </div>
</div>
{% endblock %}
