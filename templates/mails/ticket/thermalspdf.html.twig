<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
</head>
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        font-family: DejaVu Sans, sans-serif;
        font-size: 10px;
        color: #1a1a1a;
        background: #ffffff;
        width: 76mm;
    }

    /* ── Saut de page entre tickets ──────────────────────── */
    .ticket-wrapper {
        page-break-after: always;
    }
    .ticket-wrapper:last-child {
        page-break-after: avoid;
    }

    /* ── En-tête ──────────────────────────────────────────── */
    .header {
        background: #1a1a1a;
        color: #ffffff;
        text-align: center;
        padding: 10px 8px;
    }
    .header .label {
        font-size: 7px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.6;
        margin-bottom: 3px;
    }
    .header .company {
        font-size: 13px;
        font-weight: bold;
        letter-spacing: 1px;
    }
    .header .batch-info {
        font-size: 7px;
        opacity: 0.5;
        margin-top: 2px;
        letter-spacing: 1px;
    }

    /* ── Corps ────────────────────────────────────────────── */
    .body {
        padding: 8px 10px;
    }

    .section {
        padding-bottom: 8px;
        margin-bottom: 8px;
        border-bottom: 1px dashed #cccccc;
    }

    .section-label {
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: #888888;
        text-align: center;
        margin-bottom: 5px;
    }

    .trajet { text-align: center; }
    .trajet .route {
        font-size: 12px;
        font-weight: bold;
    }
    .trajet .depart {
        font-size: 8px;
        color: #666666;
        margin-top: 3px;
    }

    .info-table {
        width: 100%;
        border-collapse: collapse;
    }
    .info-table td {
        padding: 2px 0;
        vertical-align: middle;
    }
    .info-table .key {
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #888888;
        width: 40%;
    }
    .info-table .val {
        font-size: 9px;
        font-weight: bold;
        text-align: right;
    }
    .info-table .val-large {
        font-size: 16px;
        font-weight: bold;
        text-align: right;
    }

    .montant {
        text-align: right;
        font-size: 14px;
        font-weight: bold;
    }

    .code-block {
        text-align: center;
        padding: 6px;
        background: #f4f4f4;
        border-radius: 4px;
        margin: 4px 0;
    }
    .code-block .code {
        font-size: 16px;
        font-weight: bold;
        letter-spacing: 3px;
        font-family: DejaVu Sans Mono, monospace;
    }

    .cut-line {
        border-top: 2px dashed #cccccc;
        margin: 6px 0;
        text-align: center;
        position: relative;
    }
    .cut-line::before {
        content: "✂";
        font-size: 10px;
        color: #cccccc;
        background: white;
        padding: 0 4px;
        position: relative;
        top: -7px;
    }

    .footer {
        text-align: center;
        padding: 6px 8px;
        background: #f9f9f9;
    }
    .footer p {
        font-size: 7px;
        color: #aaaaaa;
        margin-bottom: 2px;
    }
</style>
<body>

{# ── Compatibilité ticket unique / lot ────────────────────────────────────── #}
{% set items = tickets is defined ? tickets : [ticket] %}
{% set total = items|length %}

{% for ticket in items %}

<div class="ticket-wrapper">

    {# ── En-tête ──────────────────────────────────────────────────────────── #}
    <div class="header">
        <div class="label">Billet de transport</div>
        <div class="company">{{ ticket.voyage.entreprise.nom ?? 'Transport' }}</div>
        {% if total > 1 %}
        <div class="batch-info">{{ loop.index }} / {{ total }}</div>
        {% endif %}
    </div>

    <div class="body">

        {# ── Trajet ───────────────────────────────────────────────────────── #}
        <div class="section">
            <div class="section-label">Trajet</div>
            <div class="trajet">
                <div class="route">
                    {{ ticket.voyage.provenance ?? '—' }} &rarr; {{ ticket.voyage.destination ?? '—' }}
                </div>
                <div class="depart">
                    Départ :
                    {{ ticket.voyage.datedebut ? ticket.voyage.datedebut|date('d/m/Y H:i') : '—' }}
                </div>
            </div>
        </div>

        {# ── Passager ─────────────────────────────────────────────────────── #}
        <div class="section">
            <table class="info-table">
                <tr>
                    <td class="key">Passager</td>
                    <td class="val">{{ ticket.nomclient ?? '—' }}</td>
                </tr>
                <tr>
                    <td class="key">Contact</td>
                    <td class="val">{{ ticket.contactclient ?? '—' }}</td>
                </tr>
                <tr>
                    <td class="key">Place N°</td>
                    <td class="val-large">{{ ticket.siege.numero }}</td>
                </tr>
            </table>
        </div>

        {# ── Montant ──────────────────────────────────────────────────────── #}
        <div class="section">
            <table class="info-table">
                <tr>
                    <td class="key">Montant payé</td>
                    <td class="montant">
                        {{ ticket.prix|number_format(0, ',', ' ') }} FCFA
                    </td>
                </tr>
            </table>
        </div>

        {# ── Code ticket ──────────────────────────────────────────────────── #}
        <div class="section-label" style="margin-bottom:4px">Code ticket</div>
        <div class="code-block">
            <div class="code">{{ ticket.codeticket }}</div>
        </div>

    </div>

    {# ── Ligne de découpe ─────────────────────────────────────────────────── #}
    <div class="cut-line"></div>

    {# ── Pied ─────────────────────────────────────────────────────────────── #}
    <div class="footer">
        <p>Émis le {{ ticket.createdAt ? ticket.createdAt|date('d/m/Y à H:i') : 'N/A' }}</p>
        <p>Présentez ce billet au départ · Non remboursable</p>
    </div>

</div>

{% endfor %}

</body>
</html>
