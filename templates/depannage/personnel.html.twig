{% extends 'base.html.twig' %}

{% block title %}Affectation de personnel - Dépannage #{{ depannage.id }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('depannage.index') }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14">
            <use href="{{ asset('sprite.svg') }}#chevron-left"></use>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2] mb-0.5">Affecter du personnel</h1>
        <p class="text-muted-foreground text-sm mt-0.5">
            Dépannage #{{ depannage.id }} {% if depannage.car %} - car: {{ depannage.car.matricule }}{% endif %}/{{ depannage.lieudepannage }}
        </p>
    </div>
</div>

<div class="rounded-xl border bg-card shadow-sm p-4 mb-4 grid grid-cols-2 gap-4 text-sm">
    <div>
        <p class="text-lg font-light text-muted-foreground mb-1">Car</p>
        <p class="font-semibold text-sm">{{ depannage.car.matricule }}</p>
    </div>
    <div>
        <p class="text-lg font-light text-muted-foreground mb-1">Lieu</p>
        <p class="font-semibold text-sm">{{ depannage.lieudepannage }}</p>
    </div>
    <div>
        <p class="text-lg font-light text-muted-foreground">Description</p>
        <p class="font-semibold text-sm">{{ depannage.description|default('..') }}</p>
    </div>
</div>

<div class="rounded-xl border bg-card shadow-sm p-6 mb-4">
    {{ form_start(form) }}
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 mb-3">
            <div>{{ form_row(form.personnel) }}</div>
            <div>{{ form_row(form.motif) }}</div>
        </div>
        <div class="flex items-center justify-end gap-3">
            <a href="{{ path('depannage.index') }}" class="btn btn-secondary">Annuler</a>
            <button class="btn btn-primary">
                Affecter
            </button>
        </div>
    {{ form_end(form) }}
</div>
{% endblock %}