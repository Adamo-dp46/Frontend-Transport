{% extends 'base.html.twig' %}
{% block title %}Modifier mon profil{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">

    <div class="flex items-center gap-3 mb-6">
        <a href="{{ path('profile.index') }}" class="btn-icon" aria-label="Retour">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
            </svg>
        </a>
        <div>
            <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Modifier mon profil</h1>
            <p class="text-muted-foreground text-sm mt-0.5">Mettez à jour vos informations personnelles</p>
        </div>
    </div>

    {% if error %}
    <div class="mb-4 flex items-start gap-2 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
        <svg class="h-4 w-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
        </svg>
        <span>{{ error }}</span>
    </div>
    {% endif %}

    <div class="rounded-xl border bg-card shadow-sm overflow-hidden">

        {# ── En-tête : avatar + identité ── #}
        <div class="flex items-center gap-4 px-6 py-5 border-b bg-muted/30">
            {% if app.user.fileUrl is defined and app.user.fileUrl %}
                <img src="{{ api_url ~ '/media' ~ app.user.fileUrl ~ '?w=160&h=160&fm=jpg&fit=crop' }}" alt="Avatar"
                     class="h-14 w-14 rounded-full object-cover ring-2 ring-primary/10"/>
            {% else %}
                <div class="h-14 w-14 rounded-full bg-primary/10 flex items-center justify-center ring-2 ring-primary/10">
                    <span class="text-lg font-bold text-primary">{{ app.user.prenom|upper|slice(0,1) }}{{ app.user.nom|upper|slice(0,1) }}</span>
                </div>
            {% endif %}
            <div class="min-w-0">
                <p class="font-semibold truncate">{{ user.prenom }} {{ user.nom }}</p>
                <p class="text-sm text-muted-foreground truncate">{{ user.email }}</p>
            </div>
        </div>

        {# ── Formulaire ── #}
        <form method="POST" action="{{ path('profile.edit') }}" class="p-6 space-y-5">

            <div class="grid gap-4 sm:grid-cols-2">
                <div class="field">
                    <label for="nom" class="label">Nom <span class="text-red-500">*</span></label>
                    <input type="text" name="nom" id="nom" required value="{{ user.nom ?? '' }}" class="input" autocomplete="family-name"/>
                </div>
                <div class="field">
                    <label for="prenom" class="label">Prénom <span class="text-red-500">*</span></label>
                    <input type="text" name="prenom" id="prenom" required value="{{ user.prenom ?? '' }}" class="input" autocomplete="given-name"/>
                </div>
            </div>

            <div class="field">
                <label for="email" class="label">Email <span class="text-red-500">*</span></label>
                <input type="email" name="email" id="email" required value="{{ user.email ?? '' }}" class="input" autocomplete="email"/>
                <p class="text-xs text-muted-foreground mt-1">Sert d'identifiant de connexion.</p>
            </div>

            <div class="flex items-center justify-end gap-3 pt-2 border-t">
                <a href="{{ path('profile.index') }}" class="btn btn-secondary">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                    Enregistrer
                </button>
            </div>

        </form>
    </div>
</div>
{% endblock %}
