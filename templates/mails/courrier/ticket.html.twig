<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'DejaVu Sans', sans-serif;
            font-size: 10px;
            color: #000;
            width: 72mm;
            padding: 4mm;
        }
        .center { text-align: center; }
        .bold { font-weight: bold; }
        .large { font-size: 13px; }
        .xlarge { font-size: 16px; }
        .separator { border-top: 1px dashed #000; margin: 4px 0; }
        .separator-solid { border-top: 1px solid #000; margin: 4px 0; }
        .row {
            display: flex;
            justify-content: space-between;
            margin: 2px 0;
        }
        .label { color: #444; }
        .value { font-weight: bold; }
        .code-block {
            text-align: center;
            font-size: 14px;
            font-weight: bold;
            letter-spacing: 2px;
            margin: 6px 0;
            padding: 4px;
            border: 1px solid #000;
        }
        .montant-block {
            text-align: center;
            margin: 6px 0;
        }
        .footer {
            font-size: 8px;
            color: #555;
            text-align: center;
            margin-top: 8px;
        }
        .colis-table {
            width: 100%;
            border-collapse: collapse;
            margin: 4px 0;
            font-size: 9px;
        }
        .colis-table th {
            border-bottom: 1px solid #000;
            padding: 2px 3px;
            text-align: left;
            font-weight: bold;
        }
        .colis-table td {
            padding: 2px 3px;
            border-bottom: 1px dashed #ccc;
        }
        .colis-table tfoot td {
            border-top: 1px solid #000;
            border-bottom: none;
            font-weight: bold;
            padding-top: 3px;
        }
    </style>
</head>
<body>

    {# -- En-tête entreprise -- #}
    <div class="center">
        <div class="bold large">{{ entreprise.libelle }}</div>
         {% if logoBase64 %}
            <img src="{{ logoBase64 }}" alt="{{ entreprise.libelle }}" style="max-width: 50mm; max-height: 20mm; object-fit: contain; margin-bottom: 4px;">
        {% endif %}
        {% if entreprise.sigle %}
            <div>{{ entreprise.sigle }}</div>
        {% endif %}
        {% if entreprise.contact1 %}
            <div>{{ entreprise.contact1 }}</div>
        {% endif %}
        {% if entreprise.adresse %}
            <div>{{ entreprise.adresse }}</div>
        {% endif %}
    </div>

    <div class="separator-solid"></div>

    <div class="center bold large">REÇU COURRIER</div>
    <div class="center" style="font-size:8px; margin-bottom: 4px;">
        {{ "now"|date("d/m/Y H:i") }}
    </div>

    <div class="separator"></div>

    {# -- Code courrier -- #}
    <div class="code-block">{{ courrier.codecourrier }}</div>

    <div class="separator"></div>

    {# -- Expéditeur -- #}
    <div style="margin-bottom: 4px;">
        <div class="bold" style="font-size: 9px; margin-bottom: 2px;">EXPÉDITEUR</div>
        <div class="row">
            <span class="label">Nom</span>
            <span class="value">{{ courrier.nomexpediteur }}</span>
        </div>
        <div class="row">
            <span class="label">Contact</span>
            <span class="value">{{ courrier.contactexpediteur }}</span>
        </div>
    </div>

    <div class="separator"></div>

    {# -- Destinataire -- #}
    <div style="margin-bottom: 4px;">
        <div class="bold" style="font-size: 9px; margin-bottom: 2px;">DESTINATAIRE</div>
        <div class="row">
            <span class="label">Nom</span>
            <span class="value">{{ courrier.nomdestinataire }}</span>
        </div>
        <div class="row">
            <span class="label">Contact</span>
            <span class="value">{{ courrier.contactdestinataire }}</span>
        </div>
    </div>

    <div class="separator"></div>

    {# -- Itinéraire -- #}
    <div style="margin-bottom: 4px;">
        <div class="bold" style="font-size: 9px; margin-bottom: 2px;">ITINÉRAIRE</div>
        <div class="row">
            <span class="label">Départ</span>
            <span class="value">{{ courrier.garedepart.libelle }}</span>
        </div>
        <div class="row">
            <span class="label">Arrivée</span>
            <span class="value">{{ courrier.garearrivee.libelle }}</span>
        </div>
        {% if courrier.voyage %}
        <div class="row">
            <span class="label">Voyage</span>
            <span class="value">{{ courrier.voyage.codevoyage }}</span>
        </div>
        {% endif %}
    </div>

    <div class="separator"></div>

    {# -- Liste des colis -- #}
    <div class="bold" style="font-size: 9px; margin-bottom: 3px;">LISTE DES COLIS</div>
    <table class="colis-table">
        <thead>
            <tr>
                <th>Nature</th>
                <th>Désignation</th>
                <th>Type</th>
                <th style="text-align:right;">Valeur</th>
                <th style="text-align:right;">Taxe</th>
            </tr>
        </thead>
        <tbody>
            {% for detail in courrier.detailcourriers %}
            <tr>
                <td>{{ detail.nature }}</td>
                <td>{{ detail.designation }}</td>
                <td>{{ detail.type }}</td>
                <td style="text-align:right;">{{ detail.valeur|number_format(0, ',', ' ') }}</td>
                <td style="text-align:right;">{{ detail.montant|number_format(0, ',', ' ') }}</td>
            </tr>
            {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="4" style="text-align:right;">Total taxe</td>
                <td style="text-align:right;">{{ courrier.montant|number_format(0, ',', ' ') }}</td>
            </tr>
        </tfoot>
    </table>

    <div class="separator-solid"></div>

    {# -- Paiement -- #}
    <div class="row" style="margin: 3px 0;">
        <span class="label">Mode paiement</span>
        <span class="value">{{ courrier.modepaiement == 'ENVOI' ? 'À l\'envoi' : 'À la réception' }}</span>
    </div>
    {% if courrier.fraissuivi %}
    <div class="row" style="margin: 3px 0;">
        <span class="label">Frais suivi SMS</span>
        <span class="value">{{ courrier.fraissuivi|number_format(0, ',', ' ') }} FCFA</span>
    </div>
    {% endif %}

    <div class="separator-solid"></div>

    {# -- Montant total -- #}
    <div class="montant-block">
        <div class="label" style="font-size:9px;">MONTANT PAYÉ</div>
        <div class="xlarge bold">
            {{ (courrier.montant + (courrier.fraissuivi ?? 0))|number_format(0, ',', ' ') }} FCFA
        </div>
        {% if courrier.modepaiement == 'RECEPTION' and courrier.estatpaiement == 'EN_ATTENTE_PAIEMENT' %}
            <div style="font-size: 8px; color: #555;">(À payer à la réception)</div>
        {% endif %}
    </div>

    <div class="separator-solid"></div>

    {# -- Statut -- #}
    {% set statutLabels = {
        EN_ATTENTE:  'En attente',
        EN_TRANSIT:  'En transit',
        RECEPTIONNE: 'Réceptionné',
        LIVRE:       'Livré',
        PERDU:       'Perdu',
        ANNULE:      'Annulé'
    } %}
    <div class="row" style="margin: 3px 0;">
        <span class="label">Statut</span>
        <span class="value">{{ statutLabels[courrier.statut] ?? courrier.statut }}</span>
    </div>

    <div class="separator"></div>

    {# -- Footer -- #}
    <div class="footer">
        <p>NB : Le paiement n'est pas remboursable</p>
        <p>Conservez ce reçu jusqu'à destination</p>
        {% if entreprise.contact1 %}
            <p>{{ entreprise.contact1 }}</p>
        {% endif %}
    </div>

</body>
</html>