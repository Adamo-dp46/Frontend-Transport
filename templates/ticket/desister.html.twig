{% extends 'base.html.twig' %}

{% block title %}Désistement — {{ ticket.codeticket }}{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-4">
    <a href="{{ path('ticket.show', { id: ticket.id }) }}" class="btn-icon">
        <svg class="h-5 w-5" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron-left"></use></svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Désistement du billet</h1>
        <p class="text-sm font-light text-muted-foreground">Reporter le client sur un autre voyage ou annuler le billet</p>
    </div>
</div>

<div {{ react_component('Billetterie/DesistementForm', {
        ticket: ticket,
        voyagesCible: voyagesCible
    }) }}
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
