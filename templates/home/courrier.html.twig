{% extends 'base.html.twig' %}

{% block title %}Courrier{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col mb-6">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Courrier</h1>
    </div>
    <form method="get" action="{{ path('stats.courrier') }}" class="flex items-center gap-2 shrink-0 max-sm:w-full">
        <input type="date" name="debut" value="{{ debut }}" class="input input-sm" />
        <span class="text-muted-foreground text-sm">→</span>
        <input type="date" name="fin" value="{{ fin }}" class="input input-sm" />
        <button type="submit" class="bg-blue-900 p-2 rounded-2xl">
            Filtrer
        </button>
    </form>
</div>

<section class="mb-10">
    <h2 class="text-lg font-medium mb-4">Courriers</h2>

    {# KPI #}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Total courriers</p>
            <p class="text-2xl font-semibold">{{ courrier.totalCourriers }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Recette totale</p>
            <p class="text-2xl font-semibold">{{ courrier.recetteTotale | number_format(0, ',', ' ') }} FCFA</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Perdus</p>
            <p class="text-2xl font-semibold {{ courrier.perdus > 0 ? 'text-red-500' : '' }}">{{ courrier.perdus }}</p>
        </div>
        <div class="card p-4">
            <p class="text-xs text-muted-foreground mb-1">Annulés</p>
            <p class="text-2xl font-semibold {{ courrier.annules > 0 ? 'text-amber-500' : '' }}">{{ courrier.annules }}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

        {# Statuts — doughnut #}
        <div class="card p-4">
            <p class="text-sm font-medium mb-3">Répartition par statut</p>
            <canvas id="chartCourrierStatuts" height="160"
                data-values="{{ [
                    {statut: 'En attente',   total: courrier.enAttente},
                    {statut: 'En transit',   total: courrier.enTransit},
                    {statut: 'Réceptionné',  total: courrier.receptionnes},
                    {statut: 'Livré',        total: courrier.livres},
                    {statut: 'Perdu',        total: courrier.perdus},
                    {statut: 'Annulé',       total: courrier.annules}
                ] | json_encode }}">
            </canvas>
        </div>

        {# Recettes par jour — barres #}
        <div class="card p-4 md:col-span-2">
            <p class="text-sm font-medium mb-3">Recettes par jour</p>
            <canvas id="chartCourrierParJour" height="160"
                data-values="{{ courrier.recettesParJour | map(r => {label: r.label, montant: r.montant, nbcourriers: r.nbcourriers}) | json_encode }}">
            </canvas>
        </div>

        {# Recettes par trajet — barres horizontales #}
        <div class="card p-4 md:col-span-3">
            <p class="text-sm font-medium mb-3">Recettes par trajet</p>
            <canvas id="chartCourrierParTrajet" height="100"
                data-values="{{ courrier.recettesParTrajet | map(r => {trajet: r.trajet, montant: r.montant, nbcourriers: r.nbcourriers}) | json_encode }}">
            </canvas>
        </div>

    </div>
</section>
{% endblock %}