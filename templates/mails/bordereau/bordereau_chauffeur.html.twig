<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 11px;
            color: #1a1a1a;
            background: #fff;
        }

        /* ── En-tête ───────────────────────────────────────── */
        .header {
            border-bottom: 3px solid #1a1a1a;
            padding-bottom: 12px;
            margin-bottom: 16px;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .company-name {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .company-sub {
            font-size: 10px;
            color: #555;
            margin-top: 2px;
        }

        .doc-title {
            text-align: right;
        }

        .doc-title h1 {
            font-size: 16px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 2px;
            border: 2px solid #1a1a1a;
            padding: 4px 12px;
            display: inline-block;
        }

        .doc-title p {
            font-size: 10px;
            color: #555;
            margin-top: 4px;
        }

        /* ── Trajet banner ─────────────────────────────────── */
        .trajet-banner {
            background: #f5f5f5;
            border: 1px solid #ddd;
            border-radius: 3px;
            padding: 10px 16px;
            margin-bottom: 16px;
            text-align: center;
        }

        .trajet-route {
            font-size: 16px;
            font-weight: bold;
            letter-spacing: 1px;
        }

        .trajet-arrow { margin: 0 10px; color: #888; }

        .trajet-meta {
            font-size: 10px;
            color: #666;
            margin-top: 4px;
        }

        /* ── Info voyage ───────────────────────────────────── */
        .info-grid {
            display: flex;
            gap: 12px;
            margin-bottom: 16px;
        }

        .info-box {
            flex: 1;
            border: 1px solid #ccc;
            border-radius: 3px;
        }

        .info-box-title {
            background: #1a1a1a;
            color: #fff;
            font-size: 9px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding: 4px 10px;
        }

        .info-box-body { padding: 8px 10px; }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 4px;
            font-size: 10.5px;
        }

        .info-row:last-child { margin-bottom: 0; }
        .info-label { color: #666; }
        .info-value { font-weight: bold; }

        /* ── KPIs ──────────────────────────────────────────── */
        .kpis {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .kpi {
            flex: 1;
            border: 1px solid #ccc;
            border-radius: 3px;
            padding: 8px 12px;
            text-align: center;
        }

        .kpi-value {
            font-size: 20px;
            font-weight: bold;
            display: block;
        }

        .kpi-label {
            font-size: 9px;
            color: #666;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* ── Section ───────────────────────────────────────── */
        .section { margin-bottom: 20px; }

        .section-title {
            font-size: 10px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            border-bottom: 1px solid #1a1a1a;
            padding-bottom: 4px;
            margin-bottom: 8px;
        }

        /* ── Tables ────────────────────────────────────────── */
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 10px;
        }

        thead tr { background: #1a1a1a; color: #fff; }

        thead th {
            padding: 6px 8px;
            text-align: left;
            font-weight: bold;
            font-size: 9px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        thead th.right { text-align: right; }
        thead th.center { text-align: center; }

        tbody tr:nth-child(even) { background: #f9f9f9; }
        tbody tr:last-child td { border-bottom: 2px solid #1a1a1a; }

        tbody td {
            padding: 5px 8px;
            border-bottom: 1px solid #e5e5e5;
        }

        tbody td.right { text-align: right; }
        tbody td.center { text-align: center; }
        tbody td.muted { color: #888; font-style: italic; }

        .badge {
            font-size: 9px;
            font-weight: bold;
            padding: 1px 6px;
            border-radius: 10px;
            display: inline-block;
        }

        .badge-dark { background: #1a1a1a; color: #fff; }
        .badge-envoi { background: #d1fae5; color: #065f46; }
        .badge-reception { background: #fef3c7; color: #92400e; }

        /* ── Signature ─────────────────────────────────────── */
        .signatures {
            display: flex;
            gap: 20px;
            margin-top: 30px;
        }

        .signature-box {
            flex: 1;
            border: 1px solid #ccc;
            text-align: center;
        }

        .signature-box-title {
            background: #f5f5f5;
            padding: 4px;
            font-size: 9px;
            font-weight: bold;
            text-transform: uppercase;
            border-bottom: 1px solid #ccc;
        }

        .signature-box-body { height: 50px; }

        /* ── Footer ────────────────────────────────────────── */
        .footer {
            margin-top: 16px;
            border-top: 1px solid #ccc;
            padding-top: 8px;
            display: flex;
            justify-content: space-between;
            font-size: 9px;
            color: #888;
        }
    </style>
</head>
<body>

    {# ── En-tête ─────────────────────────────────────────────── #}
    <div class="header">
        <div class="header-top">
            <div>
                <p class="company-name">Compagnie de Transport</p>
                <p class="company-sub">Bordereau de transport — Document chauffeur</p>
            </div>
            <div class="doc-title">
                <h1>Bordereau Chauffeur</h1>
                <p>Généré le {{ bordereau.generele }}</p>
            </div>
        </div>
    </div>

    {# ── Trajet ──────────────────────────────────────────────── #}
    <div class="trajet-banner">
        <div class="trajet-route">
            {{ bordereau.voyage.provenance }}
            <span class="trajet-arrow">→</span>
            {{ bordereau.voyage.destination }}
        </div>
        <div class="trajet-meta">
            {{ bordereau.voyage.codevoyage }}
            &nbsp;·&nbsp;
            Départ le {{ bordereau.voyage.datedebut }}
            {% if bordereau.voyage.matricule %}
                &nbsp;·&nbsp; Véhicule : {{ bordereau.voyage.matricule }}
            {% endif %}
        </div>
    </div>

    {# ── Infos voyage ────────────────────────────────────────── #}
    <div class="info-grid">
        <div class="info-box">
            <div class="info-box-title">Voyage</div>
            <div class="info-box-body">
                <div class="info-row">
                    <span class="info-label">Code</span>
                    <span class="info-value">{{ bordereau.voyage.codevoyage }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Départ</span>
                    <span class="info-value">{{ bordereau.voyage.datedebut }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Véhicule</span>
                    <span class="info-value">{{ bordereau.voyage.matricule ?? '—' }}</span>
                </div>
            </div>
        </div>
        <div class="info-box">
            <div class="info-box-title">Capacité</div>
            <div class="info-box-body">
                <div class="info-row">
                    <span class="info-label">Places total</span>
                    <span class="info-value">{{ bordereau.voyage.placestotal }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Occupées</span>
                    <span class="info-value">{{ bordereau.voyage.placesoccupees }}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Disponibles</span>
                    <span class="info-value">{{ bordereau.voyage.placestotal - bordereau.voyage.placesoccupees }}</span>
                </div>
            </div>
        </div>
    </div>

    {# ── KPIs ────────────────────────────────────────────────── #}
    <div class="kpis">
        <div class="kpi">
            <span class="kpi-value">{{ bordereau.totalTickets }}</span>
            <span class="kpi-label">Passagers</span>
        </div>
        <div class="kpi">
            <span class="kpi-value">{{ bordereau.totalCourriers }}</span>
            <span class="kpi-label">Courriers</span>
        </div>
        <div class="kpi">
            <span class="kpi-value">{{ bordereau.totalBagages }}</span>
            <span class="kpi-label">Bagages</span>
        </div>
    </div>

    {# ── Passagers ───────────────────────────────────────────── #}
    <div class="section">
        <p class="section-title">Passagers ({{ bordereau.totalTickets }})</p>
        {% if bordereau.tickets is empty %}
            <p style="color:#888; font-size:10px;">Aucun passager.</p>
        {% else %}
        <table>
            <thead>
                <tr>
                    <th style="width:30px;">#</th>
                    <th class="center" style="width:50px;">Siège</th>
                    <th>Code ticket</th>
                    <th>Nom client</th>
                    <th>Contact</th>
                    <th class="right">Prix</th>
                </tr>
            </thead>
            <tbody>
                {% for t in bordereau.tickets %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td class="center">
                        <span class="badge badge-dark">{{ t.siegenumero }}</span>
                    </td>
                    <td style="font-family: monospace; font-size: 9px;">{{ t.codeticket }}</td>
                    <td>{{ t.nomclient ?? '—' }}</td>
                    <td>{{ t.contactclient ?? '—' }}</td>
                    <td class="right">{{ t.prix | number_format(0, ',', ' ') }} FCFA</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    {# ── Courriers ───────────────────────────────────────────── #}
    <div class="section">
        <p class="section-title">Courriers ({{ bordereau.totalCourriers }})</p>
        {% if bordereau.courriers is empty %}
            <p style="color:#888; font-size:10px;">Aucun courrier.</p>
        {% else %}
        <table>
            <thead>
                <tr>
                    <th style="width:30px;">#</th>
                    <th>Code</th>
                    <th>Expéditeur</th>
                    <th>Destinataire</th>
                    <th>Départ → Arrivée</th>
                    <th class="center">Colis</th>
                    <th class="right">Montant</th>
                    <th class="center">Paiement</th>
                </tr>
            </thead>
            <tbody>
                {% for c in bordereau.courriers %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td style="font-family: monospace; font-size: 9px;">{{ c.codecourrier }}</td>
                    <td>{{ c.nomexpediteur }}</td>
                    <td>{{ c.nomdestinataire }}</td>
                    <td>{{ c.garedepart }} → {{ c.garearrivee }}</td>
                    <td class="center">{{ c.nbcolis }}</td>
                    <td class="right">{{ c.montant | number_format(0, ',', ' ') }} FCFA</td>
                    <td class="center">
                        <span class="badge {{ c.modepaiement == 'ENVOI' ? 'badge-envoi' : 'badge-reception' }}">
                            {{ c.modepaiement }}
                        </span>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    {# ── Bagages ─────────────────────────────────────────────── #}
    <div class="section">
        <p class="section-title">Bagages ({{ bordereau.totalBagages }})</p>
        {% if bordereau.bagages is empty %}
            <p style="color:#888; font-size:10px;">Aucun bagage.</p>
        {% else %}
        <table>
            <thead>
                <tr>
                    <th style="width:30px;">#</th>
                    <th>Code</th>
                    <th>Client</th>
                    <th>Nature</th>
                    <th>Type</th>
                    <th class="right">Poids</th>
                    <th class="right">Montant</th>
                </tr>
            </thead>
            <tbody>
                {% for b in bordereau.bagages %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td style="font-family: monospace; font-size: 9px;">{{ b.codebagage }}</td>
                    <td>{{ b.nomclient }}</td>
                    <td>{{ b.nature }}</td>
                    <td>{{ b.type ?? '—' }}</td>
                    <td class="right">{{ b.poids }} kg</td>
                    <td class="right">{{ b.montant | number_format(0, ',', ' ') }} FCFA</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    {# ── Signatures ──────────────────────────────────────────── #}
    <div class="signatures">
        <div class="signature-box">
            <div class="signature-box-title">Signature chauffeur</div>
            <div class="signature-box-body"></div>
        </div>
        <div class="signature-box">
            <div class="signature-box-title">Signature agent gare d'arrivée</div>
            <div class="signature-box-body"></div>
        </div>
    </div>

    {# ── Footer ──────────────────────────────────────────────── #}
    <div class="footer">
        <span>{{ bordereau.voyage.codevoyage }} — {{ bordereau.voyage.provenance }} → {{ bordereau.voyage.destination }}</span>
        <span>Document généré automatiquement le {{ bordereau.generele }}</span>
    </div>

</body>
</html>