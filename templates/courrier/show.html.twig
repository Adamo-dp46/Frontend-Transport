{% extends 'base.html.twig' %}

{% block title %}Courrier {{ courrier.codecourrier }}{% endblock %}

{% block body %}
{% set statutMap = {
    EN_ATTENTE:  ['En attente',   'bg-gray-100 text-gray-700'],
    EN_TRANSIT:  ['En transit',   'bg-blue-100 text-blue-800'],
    RECEPTIONNE: ['Réceptionné',  'bg-orange-100 text-orange-800'],
    LIVRE:       ['Livré',        'bg-green-100 text-green-800'],
    ANNULE:      ['Annulé',       'bg-red-100 text-red-800']
} %}
{% set paiementMap = {
    ENVOI:     ['Payé à l\'envoi',     'bg-green-100 text-green-800'],
    RECEPTION: ['Payé à la réception', 'bg-orange-100 text-orange-800']
} %}
{% set statutCfg  = statutMap[courrier.statut]    ?? [courrier.statut, 'bg-gray-100 text-gray-700'] %}
{% set paiementCfg= paiementMap[courrier.modepaiement] ?? [courrier.modepaiement, 'bg-gray-100 text-gray-700'] %}
<div class="flex flex-col mb-5 gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
        <h1 class="text-2xl font-bold tracking-[-0.55px] leading-tight mb-1">
            Courrier {{ courrier.codecourrier }}
        </h1>
        <p class="text-sm font-light text-muted-foreground">
            Créé le {{ courrier.createdAt|date('d/m/Y à H:i') }}
        </p>
    </div>
    <div class="flex items-center gap-2 flex-wrap sm:shrink-0">
        <a href="{{ path('courrier.index') }}" class="btn btn-secondary">
            <svg class="h-5 w-5" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#chevron-left"></use></svg>
            Retour
        </a>
        {% if is_granted('COURRIER_MODIFIER') and courrier.statut == 'EN_ATTENTE' %}
        <a href="{{ path('courrier.edit', { id: courrier.id }) }}" class="btn btn-primary">
            <svg class="nav-item-icon" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#edit"></use></svg>
            Modifier
        </a>
        {% endif %}
        {% if is_granted('COURRIER_MODIFIER') and courrier.statut == 'RECEPTIONNE' %}
        <form method="POST" action="{{ path('courrier.livrer', { id: courrier.id }) }}" class="inline">
            <button type="submit" class="btn btn-primary" onclick="return confirm('Confirmer la livraison ?')">
                Confirmer la livraison
            </button>
        </form>
        {% endif %}
        {% if is_granted('COURRIER_MODIFIER') and courrier.statut == 'EN_TRANSIT' %}
        <form method="POST" action="{{ path('courrier.perdu', { id: courrier.id }) }}" class="inline">
            <button type="submit" class="btn btn-warning" onclick="return confirm('Déclarer ce courrier comme perdu ?')">
                Déclarer perdu
            </button>
        </form>
        {% endif %}
        {% if is_granted('COURRIER_MODIFIER') and courrier.statut == 'EN_ATTENTE' %}
        <form method="POST" action="{{ path('courrier.annuler', { id: courrier.id }) }}" class="inline">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Annuler ce courrier ?')">
                Annuler
            </button>
        </form>
        {% endif %}
        {% if is_granted('COURRIER_VOIR') %}
        <a href="{{ path('courrier.print', { id: courrier.id }) }}" target="_blank" class="btn btn-secondary">
            <svg class="h-5 w-5" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#print"></use></svg>
            Imprimer le reçu
        </a>
        {% endif %}
        {% if is_granted('COURRIER_SUPPRIMER') and courrier.statut == 'EN_ATTENTE' %}
        <form method="POST" action="{{ path('courrier.delete', { id: courrier.id }) }}" class="inline"
              onsubmit="return confirm('Supprimer ce courrier ?')">
            <button type="submit" class="btn btn-danger">Supprimer</button>
        </form>
        {% endif %}
    </div>
</div>

{# -- Statuts -- #}
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
    <div class="rounded-xl border bg-card shadow-sm p-4">
        <p class="text-sm font-light text-muted-foreground mb-2">Statut</p>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium {{ statutCfg[1] }}">
            {{ statutCfg[0] }}
        </span>
    </div>
    <div class="rounded-xl border bg-card shadow-sm p-4">
        <p class="text-sm font-light text-muted-foreground mb-2">Mode paiement</p>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium {{ paiementCfg[1] }}">
            {{ paiementCfg[0] }}
        </span>
    </div>
    <div class="rounded-xl border bg-card shadow-sm p-4">
        <p class="text-sm font-light text-muted-foreground mb-2">Montant total</p>
        <p class="font-bold text-lg">{{ courrier.montant|number_format(0, ',', ' ') }} FCFA</p>
    </div>
    <div class="rounded-xl border bg-card shadow-sm p-4">
        <p class="text-sm font-light text-muted-foreground mb-2">Frais de suivi</p>
        <p class="font-semibold">{{ courrier.fraissuivi ? courrier.fraissuivi|number_format(0, ',', ' ') ~ ' FCFA' : '—' }}</p>
    </div>
</div>

{# -- Expéditeur / Destinataire / Itinéraire -- #}
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
    <div class="card p-4">
        <p class="text-sm font-light text-muted-foreground mb-3">Expéditeur</p>
        <p class="font-semibold">{{ courrier.nomexpediteur }}</p>
        <p class="text-sm text-muted-foreground">{{ courrier.contactexpediteur }}</p>
    </div>
    <div class="card p-4">
        <p class="text-sm font-light text-muted-foreground mb-3">Destinataire</p>
        <p class="font-semibold">{{ courrier.nomdestinataire }}</p>
        <p class="text-sm text-muted-foreground">{{ courrier.contactdestinataire }}</p>
    </div>
    <div class="card p-4">
        <p class="text-sm font-light text-muted-foreground mb-3">Itinéraire</p>
        <p class="font-semibold">{{ courrier.garedepart.libelle }}</p>
        <p class="text-xs text-muted-foreground mb-1">→</p>
        <p class="font-semibold">{{ courrier.garearrivee.libelle }}</p>
        {% if courrier.voyage %}
        <p class="text-xs text-muted-foreground mt-2">
            Voyage : <span class="font-mono">{{ courrier.voyage.codevoyage }}</span>
        </p>
        {% endif %}
    </div>
</div>

{# -- Liste des colis -- #}
<div class="card mb-6">
    <div class="flex items-center justify-between px-6 py-4 border-b">
        <h2 class="text-sm font-semibold">Liste des colis</h2>
        <span class="tag tag-sky font-bold">{{ courrier.detailcourriers|length }}</span>
    </div>
    {% if courrier.detailcourriers is empty %}
        <div class="px-6 py-8 text-center text-sm text-muted-foreground">Aucun colis</div>
    {% else %}
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-muted/40 border-b">
                        <th class="text-left px-4 py-3 font-semibold">Nature</th>
                        <th class="text-left px-4 py-3 font-semibold">Désignation</th>
                        <th class="text-left px-4 py-3 font-semibold">Emballage</th>
                        <th class="text-left px-4 py-3 font-semibold">Type</th>
                        <th class="text-left px-4 py-3 font-semibold">Poids</th>
                        <th class="text-left px-4 py-3 font-semibold">Valeur</th>
                        <th class="text-right px-4 py-3 font-semibold">Taxe</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    {% for detail in courrier.detailcourriers %}
                    <tr class="hover:bg-muted/20 transition-colors">
                        <td class="px-4 py-3">{{ detail.nature }}</td>
                        <td class="px-4 py-3 font-medium">{{ detail.designation }}</td>
                        <td class="px-4 py-3 text-muted-foreground">{{ detail.emballage ?? '—' }}</td>
                        <td class="px-4 py-3">
                            {% set typeMap = { NORMAL: ['Normal','bg-gray-100 text-gray-700'], FRAGILE: ['Fragile','bg-yellow-100 text-yellow-800'], VOLUMINEUX: ['Volumineux','bg-purple-100 text-purple-800'] } %}
                            {% set tc = typeMap[detail.type] ?? [detail.type,'bg-gray-100 text-gray-700'] %}
                            <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium {{ tc[1] }}">{{ tc[0] }}</span>
                        </td>
                        <td class="px-4 py-3 text-muted-foreground">{{ detail.poids ? detail.poids ~ ' kg' : '—' }}</td>
                        <td class="px-4 py-3">{{ detail.valeur|number_format(0, ',', ' ') }} FCFA</td>
                        <td class="px-4 py-3 text-right font-semibold">{{ detail.montant|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="border-t bg-muted/20">
                        <td colspan="6" class="px-4 py-3 text-right font-semibold">Total taxe</td>
                        <td class="px-4 py-3 text-right font-bold">{{ courrier.montant|number_format(0, ',', ' ') }} FCFA</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    {% endif %}
</div>
{% endblock %}