<div class="detail-row border rounded-lg p-4 bg-muted/20 relative">
    <button type="button" class="btn-remove-detail absolute top-3 right-3 text-muted-foreground hover:text-red-500">
        <svg class="h-4 w-4" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#trash"></use></svg>
    </button>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
        <div class="field">
            <label class="label">Nature <span class="text-red-500">*</span></label>
            <input type="text" name="detail_nature[]" class="input" value="{{ detail.nature ?? '' }}" placeholder="Ex: Matériel électronique" required>
        </div>
        <div class="field">
            <label class="label">Désignation <span class="text-red-500">*</span></label>
            <input type="text" name="detail_designation[]" class="input" value="{{ detail.designation ?? '' }}" placeholder="Ex: CAPTEUR" required>
        </div>
        <div class="field">
            <label class="label">Emballage</label>
            <input type="text" name="detail_emballage[]" class="input" value="{{ detail.emballage ?? '' }}" placeholder="Ex: Sachet Blanc">
        </div>
        <div class="field">
            <label class="label">Type <span class="text-red-500">*</span></label>
            <select name="detail_type[]" class="input" required>
                {% for val, label in { NORMAL: 'Normal', FRAGILE: 'Fragile', VOLUMINEUX: 'Volumineux' } %}
                    <option value="{{ val }}" {{ (detail.type ?? 'NORMAL') == val ? 'selected' : '' }}>
                        {{ label }}
                    </option>
                {% endfor %}
            </select>
        </div>
        <div class="field">
            <label class="label">Poids (kg)</label>
            <input type="number" name="detail_poids[]" class="input" min="0" step="0.1" value="{{ detail.poids ?? '' }}" placeholder="Optionnel">
        </div>

        {# -- Tranche tarifaire + valeur liée -- #}
        <div class="field sm:col-span-2">
            <label class="label">Tranche tarifaire <span class="text-red-500">*</span></label>
            <select name="detail_tarif[]" class="input detail-tarif-select" required data-valeurmin="" data-valeurmax="">
                <option value="">-- Choisir une tranche --</option>
                {% for tarif in tarifcourriers %}
                    <option
                        value="{{ tarif.id }}"
                        data-valeurmin="{{ tarif.valeurmin }}"
                        data-valeurmax="{{ tarif.valeurmax ?? '' }}"
                        data-taxe="{{ tarif.montanttaxe }}"
                        {% if detail is not null and detail.tarifcourrier is defined and detail.tarifcourrier.id == tarif.id %}
                            selected
                        {% endif %}
                    >
                        {{ tarif.libelle }} —
                        {{ tarif.valeurmin|number_format(0, ',', ' ') }} FCFA
                        {% if tarif.valeurmax %}
                            → {{ tarif.valeurmax|number_format(0, ',', ' ') }} FCFA
                        {% else %}
                            → Illimité
                        {% endif %}
                        (taxe : {{ tarif.montanttaxe|number_format(0, ',', ' ') }} FCFA)
                    </option>
                {% endfor %}
            </select>
        </div>

        <div class="field">
            <label class="label">
                Valeur du colis (FCFA) <span class="text-red-500">*</span>
                <span class="text-xs text-muted-foreground ml-1" id="valeur-hint-__INDEX__"></span>
            </label>
            <input type="number" name="detail_valeur[]" class="input detail-valeur-input" min="1" value="{{ detail.valeur ?? '' }}" required>
            <p class="text-xs text-muted-foreground mt-1">Doit être dans la tranche choisie</p>
        </div>
    </div>
</div>