{% extends 'base.html.twig' %}

{% block title %}La liste des lignes{% endblock %}

{% block body %}
<div class="flex items-start justify-between gap-4 max-sm:flex-col max-sm:gap-3 mb-5">
    <div>
        <h1 class="text-4xl font-light tracking-[-0.55px] leading-[1.2]">Gestion des lignes</h1>
    </div>
    <div class="flex items-center gap-2 shrink-0 max-sm:w-full">
        {% if is_granted('LIGNE_CREER') %}
        <a href="{{ path('ligne.new') }}" class="btn btn-primary max-sm:flex-1 max-sm:justify-center">
            <svg class="h-4 w-4" aria-hidden="true">
                <use href="{{ asset('sprite.svg') }}#new"></use>
            </svg>
            Nouvelle ligne
        </a>
        {% endif %}
    </div>
</div>

<div {{ react_component('Exploitation/LigneTable', {
        lignes: lignes,
        canEdit: is_granted('LIGNE_MODIFIER'),
        canDelete: is_granted('LIGNE_SUPPRIMER'),
        csrfDelete: csrf_token('delete_ligne')
    }) }}
>
    <div class="flex items-center justify-center gap-6">
        <twig:Spinner class="size-8" />
    </div>
</div>
{% endblock %}
