{% extends 'base.html.twig' %}

{% block title %}{{ trajet.provenance }} → {{ trajet.destination }}{% endblock %}

{% block body %}
<div class="max-w-[1000px] mx-auto">
    <div class="card p-6 mb-3">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
            <div>
                <div class="flex items-center gap-2 mb-0.5">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-mono font-medium bg-zinc-100 text-zinc-700 ring-1 ring-zinc-200">
                        {{ trajet.codetrajet }}
                    </span>
                </div>
                <h1 class="text-2xl font-bold flex items-center gap-3">
                    {{ trajet.provenance }}
                    <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5-5 5M6 12h12"/>
                    </svg>
                    {{ trajet.destination }}
                </h1>
            </div>
            <div class="text-right shrink-0">
                <p class="text-xs text-muted-foreground uppercase tracking-wide font-medium mb-0.5">Tarif</p>
                <p class="text-2xl font-bold">
                    {{ trajet.tarif.montant|number_format(0, ',', ' ') }} FCFA
                </p>
            </div>
        </div> 
    </div>

    <div class="card p-6">
        <h3 class="text-3xl font-light mb-3">Voyages liées ({{ totalItems }}) au total</h3>
        <div {{ react_component('Exploitation/TrajetVoyageTable', {
                voyages: voyages
            }) }}
        >
            <div class="flex items-center justify-center gap-6">
                <twig:Spinner class="size-8" />
            </div>
        </div>
        {% if totalPages > 1 %}
        <div class="flex items-center justify-between mt-4 flex-wrap gap-3">
            <p class="text-sm text-muted-foreground">
                <strong>{{ totalItems }}</strong> voyage{{ totalItems > 1 ? 's' : '' }}
                · page <strong>{{ page }}</strong> sur <strong>{{ totalPages }}</strong>
            </p>

            <div class="flex items-center gap-1 flex-wrap">
                {# Première #}
                <a href="{{ path('trajet.show', { id: trajet.id, page: 1, itemsPerPage: itemsPerPage }) }}"
                class="btn-icon {{ page == 1 ? 'opacity-40 pointer-events-none' : '' }}">«</a>

                {# Précédente #}
                <a href="{{ path('trajet.show', { id: trajet.id, page: page - 1, itemsPerPage: itemsPerPage }) }}"
                class="btn-icon {{ page == 1 ? 'opacity-40 pointer-events-none' : '' }}">‹</a>

                {# Fenêtre de 5 pages #}
                {% for p in max(1, page - 2)..min(totalPages, page + 2) %}
                <a href="{{ path('trajet.show', { id: trajet.id, page: p, itemsPerPage: itemsPerPage }) }}"
                class="btn-icon {{ p == page ? 'bg-primary text-primary-foreground' : '' }}">
                    {{ p }}
                </a>
                {% endfor %}

                {# Suivante #}
                <a href="{{ path('trajet.show', { id: trajet.id, page: page + 1, itemsPerPage: itemsPerPage }) }}"
                class="btn-icon {{ page == totalPages ? 'opacity-40 pointer-events-none' : '' }}">›</a>

                {# Dernière #}
                <a href="{{ path('trajet.show', { id: trajet.id, page: totalPages, itemsPerPage: itemsPerPage }) }}"
                class="btn-icon {{ page == totalPages ? 'opacity-40 pointer-events-none' : '' }}">»</a>
            </div>
        </div>
        {% else %}
        <p class="text-sm text-muted-foreground mt-4">
            <strong>{{ totalItems }}</strong> voyage{{ totalItems > 1 ? 's' : '' }}
        </p>
        {% endif %}
    </div>
</div>
{% endblock %}