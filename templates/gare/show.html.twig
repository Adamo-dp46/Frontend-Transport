{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}La gare - {{ gare.libelle }}{% endblock %}

{% block body %}
<div class="max-w-[1000px] mx-auto">

    {# En-tête #}
    <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
        <div class="min-w-0">
            <a href="{{ path('gare.index') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-2">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
                Retour aux gares
            </a>
            <p class="text-xs uppercase tracking-wide text-muted-foreground mb-0.5">Gare</p>
            <h1 class="text-3xl font-light tracking-[-0.5px] leading-[1.2] break-words">{{ gare.libelle }}</h1>
            <p class="text-sm text-muted-foreground mt-1 flex items-center gap-2 flex-wrap">
                {% if gare.ville %}<span>{{ gare.ville }}</span>{% endif %}
                {% if gare.statut %}{{ ui.badge(gare.statut == 'ACTIF' ? 'Active' : gare.statut|capitalize, gare.statut == 'ACTIF' ? 'green' : 'amber') }}{% endif %}
            </p>
        </div>
        {% if is_granted('GARE_MODIFIER') %}
        <div class="flex items-center gap-2 flex-wrap shrink-0">
            <a href="{{ path('gare.edit', {id: gare.id}) }}" class="btn btn-primary">
                <svg class="nav-item-icon" aria-hidden="true"><use href="{{ asset('sprite.svg') }}#edit"></use></svg>
                Modifier
            </a>
        </div>
        {% endif %}
    </div>

    {# Informations #}
    <div class="card p-6 mb-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground mb-4">Informations</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-x-6 gap-y-4">
            {{ ui.field('Chef de gare', gare.chefgare) }}
            {{ ui.field('Ville', gare.ville) }}
            {{ ui.field('Libellé', gare.libelle) }}
            {{ ui.field('Contact 1', gare.contact1) }}
            {{ ui.field('Contact 2', gare.contact2) }}
            {% if gare.datecreation is defined and gare.datecreation %}{{ ui.field('Date de création', gare.datecreation|date('d/m/Y')) }}{% endif %}
        </div>
        {% if gare.description %}
        <div class="mt-4 pt-4 border-t border-border">
            {{ ui.field('Description', gare.description) }}
        </div>
        {% endif %}
    </div>

    {# Agents de la gare #}
    {% if is_granted('USER_VOIR') or is_granted('ROLE_SUPER_ADMIN') %}
    <div class="card p-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-muted-foreground">Utilisateurs de la gare</h2>
            <span class="text-xs text-muted-foreground">{{ users|length }} utilisateur(s)</span>
        </div>
        {% if users|length > 0 %}
        <div class="overflow-hidden rounded-lg border border-border">
            <table class="w-full text-sm">
                <thead>
                    <tr class="text-left text-muted-foreground border-b border-border bg-muted/40">
                        <th class="px-4 py-2.5 font-medium">Nom</th>
                        <th class="px-4 py-2.5 font-medium">Email</th>
                        <th class="px-4 py-2.5 font-medium">Rôle</th>
                        <th class="px-4 py-2.5 font-medium text-center">Statut</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    {% for u in users %}
                    <tr class="hover:bg-muted/30 transition-colors">
                        <td class="px-4 py-2.5 font-medium">
                            <a href="{{ path('admin.user.show', {id: u.id}) }}" class="hover:text-primary hover:underline">{{ u.prenom }} {{ u.nom }}</a>
                        </td>
                        <td class="px-4 py-2.5 text-muted-foreground">{{ u.email }}</td>
                        <td class="px-4 py-2.5">
                            {% if u.founder %}{{ ui.badge('👑 Fondateur', 'amber') }}
                            {% elseif 'ROLE_ADMIN_GARE' in u.roles %}{{ ui.badge('Admin de gare', 'blue') }}
                            {% elseif 'ROLE_ADMIN' in u.roles %}{{ ui.badge('Admin', 'purple') }}
                            {% else %}{{ ui.badge('Utilisateur', 'zinc') }}{% endif %}
                        </td>
                        <td class="px-4 py-2.5 text-center">
                            {{ ui.badge(u.statut == 'ACTIF' ? 'Actif' : 'Suspendu', u.statut == 'ACTIF' ? 'green' : 'red') }}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <p class="text-sm text-muted-foreground py-4 text-center">Aucun utilisateur rattaché à cette gare.</p>
        {% endif %}
    </div>
    {% endif %}
</div>
{% endblock %}
