{% extends 'base.html.twig' %}
{% block title %}Changer mon mot de passe{% endblock %}

{% block body %}
<div class="flex items-center gap-3 mb-6">
    <a href="{{ path('profile.index') }}"
       class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
    </a>
    <div>
        <h1 class="text-3xl font-light tracking-[-0.55px] leading-[1.2]">Changer mon mot de passe</h1>
        <p class="text-muted-foreground text-sm mt-0.5">Choisissez un mot de passe sécurisé d'au moins 8 caractères</p>
    </div>
</div>

{% if error %}
<div class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">
    {{ error }}
</div>
{% endif %}

<div class="max-w-lg rounded-xl border bg-card shadow-sm p-6">
    <form method="POST" action="{{ path('profile.password') }}" class="space-y-4" id="form-password">

        <div class="space-y-1.5">
            <label for="currentPassword" class="text-sm font-medium">
                Mot de passe actuel <span class="text-red-500">*</span>
            </label>
            <div class="relative">
                <input type="password" name="currentPassword" id="currentPassword" required
                       placeholder="••••••••"
                       class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 pr-10 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"/>
                <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="currentPassword">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>
        </div>

        <div class="space-y-1.5">
            <label for="newPassword" class="text-sm font-medium">
                Nouveau mot de passe <span class="text-red-500">*</span>
            </label>
            <div class="relative">
                <input type="password" name="newPassword" id="newPassword" required
                       placeholder="••••••••" minlength="8"
                       class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 pr-10 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                       oninput="checkStrength(this.value)"/>
                <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="newPassword">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>
            {# Indicateur de force #}
            <div class="space-y-1">
                <div class="flex gap-1">
                    <div id="bar-1" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                    <div id="bar-2" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                    <div id="bar-3" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                    <div id="bar-4" class="h-1 flex-1 rounded-full bg-muted transition-colors"></div>
                </div>
                <p id="strength-label" class="text-xs text-muted-foreground"></p>
            </div>
        </div>

        <div class="space-y-1.5">
            <label for="confirmPassword" class="text-sm font-medium">
                Confirmer le nouveau mot de passe <span class="text-red-500">*</span>
            </label>
            <div class="relative">
                <input type="password" name="confirmPassword" id="confirmPassword" required
                       placeholder="••••••••"
                       class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 pr-10 text-sm shadow-sm focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                       oninput="checkConfirm()"/>
                <button type="button" class="btn-toggle-pwd absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-foreground" data-target="confirmPassword">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                </button>
            </div>
            <p id="confirm-hint" class="text-xs hidden"></p>
        </div>

        <div class="flex items-center justify-end gap-3 pt-2">
            <a href="{{ path('profile.index') }}"
               class="inline-flex items-center rounded-md border px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                Annuler
            </a>
            <button type="submit"
                    class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90 transition-colors">
                🔑 Mettre à jour
            </button>
        </div>

    </form>
</div>

<script>
// ── Afficher/masquer mot de passe ─────────────────────────────────────────────
document.querySelectorAll('.btn-toggle-pwd').forEach(btn => {
    btn.addEventListener('click', function () {
        const input = document.getElementById(this.dataset.target)
        input.type = input.type === 'password' ? 'text' : 'password'
    })
})

// ── Indicateur de force ───────────────────────────────────────────────────────
function checkStrength(value) {
    let score = 0
    if (value.length >= 8)                   score++
    if (/[A-Z]/.test(value))                 score++
    if (/[0-9]/.test(value))                 score++
    if (/[^A-Za-z0-9]/.test(value))          score++

    const bars   = [1,2,3,4].map(i => document.getElementById('bar-' + i))
    const label  = document.getElementById('strength-label')
    const colors = ['bg-red-500', 'bg-orange-400', 'bg-yellow-400', 'bg-green-500']
    const labels = ['Très faible', 'Faible', 'Moyen', 'Fort']

    bars.forEach((bar, i) => {
        bar.className = 'h-1 flex-1 rounded-full transition-colors ' + (i < score ? colors[score - 1] : 'bg-muted')
    })

    label.textContent = value.length > 0 ? labels[score - 1] ?? '' : ''
    label.className   = 'text-xs ' + (score <= 1 ? 'text-red-500' : score <= 2 ? 'text-orange-500' : score === 3 ? 'text-yellow-600' : 'text-green-600')
}

// ── Vérification correspondance ───────────────────────────────────────────────
function checkConfirm() {
    const newPwd     = document.getElementById('newPassword').value
    const confirmPwd = document.getElementById('confirmPassword').value
    const hint       = document.getElementById('confirm-hint')

    if (!confirmPwd) { hint.classList.add('hidden'); return }

    if (newPwd === confirmPwd) {
        hint.textContent  = '✓ Les mots de passe correspondent'
        hint.className    = 'text-xs text-green-600'
        hint.classList.remove('hidden')
    } else {
        hint.textContent  = '✗ Les mots de passe ne correspondent pas'
        hint.className    = 'text-xs text-red-600'
        hint.classList.remove('hidden')
    }
}
</script>
{% endblock %}
