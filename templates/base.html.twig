                    <div class="sidebar-section">
                        <div class="sb-section-title">Ressources humaines</div>

                        <button class="nav-link" data-submenu="sub-personnel" title="Personnel">
                            <svg class="nav-icon" aria-hidden="true">
                                <use href="{{ asset('sprite.svg') }}#personnel"></use>
                            </svg>
                            <span class="sb-text">Personnel</span>
                            <svg class="submenu-arrow" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron"></use></svg>
                        </button>
                        <div class="submenu" id="sub-personnel">
                            <div class="submenu-inner">
                                {% if is_granted('TYPEPERSONNEL_VOIR') %}
                                <a href="{{ path('typepersonnel.index') }}" class="sub-link {{ app.current_route starts with 'typepersonnel.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Type de personnel
                                </a>
                                {% endif %}
                                {% if is_granted('PERSONNEL_VOIR') %}
                                <a href="{{ path('personnel.index') }}" class="sub-link {{ app.current_route starts with 'personnel.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Personnel
                                </a>
                                {% endif %}
                            </div>
                        </div>

                        <button class="nav-link" data-submenu="sub-admin" title="Administration">
                            <svg class="nav-icon" aria-hidden="true">
                                <use href="{{ asset('sprite.svg') }}#admin"></use>
                            </svg>
                            <span class="sb-text">Administration</span>
                            <svg class="submenu-arrow" aria-hidden="true" width="14" height="14"><use href="{{ asset('sprite.svg') }}#chevron"></use></svg>
                        </button>
                        <div class="submenu" id="sub-admin">
                            <div class="submenu-inner">
                                {% if is_granted('ROLE_VOIR') %}
                                <a href="{{ path('admin.role.index') }}" class="sub-link {{ app.current_route starts with 'admin.role.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Roles & Permissions
                                </a>
                                {% endif %}
                                {% if is_granted('USER_VOIR') or is_granted('ROLE_SUPER_ADMIN') %}
                                <a href="{{ path('admin.user.index') }}" class="sub-link {{ app.current_route starts with 'admin.user.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Utilisateurs
                                </a>
                                {% endif %}
                                {% if is_granted('ROLE_SUPER_ADMIN') %}
                                <a href="{{ path('admin.entreprise.index') }}" class="sub-link {{ app.current_route starts with 'admin.entreprise.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Entreprises
                                </a>
                                {% elseif is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin.entreprise.me') }}" class="sub-link {{ app.current_route starts with 'admin.entreprise.' ? 'active' : '' }}" data-subnav>
                                    <span class="sub-dot"></span>Entreprise
                                </a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </nav>

                <div class="sidebar-footer">
                    <div class="dropdown-anchor">
                        <button class="sb-footer-user" id="sidebarUserBtn">
                        <div class="user-avatar">
                            {{ app.user.nom|slice(0,1)|upper }}{{ app.user.prenom|slice(0,1)|upper }}
                        </div>
                        <div class="user-info">
                            <span class="user-name">{{ app.user.nom }}</span>
                            <span class="user-email">{{ app.user.email }}</span>
                        </div>
                            <svg class="user-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7 15 5 5 5-5"/><path d="m7 9 5-5 5 5"/></svg>
                        </button>
                        <div class="dropdown" id="sidebarUserDrop" style="bottom:calc(100% + .375rem);top:auto;right:0;left:0;min-width:220px;">
                            <div class="dropdown-header">
