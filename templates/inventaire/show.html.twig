{% extends 'base.html.twig' %}
{% import 'components/detail.html.twig' as ui %}

{% block title %}Inventaire #{{ inventaire.id }}{% endblock %}

{% set isEntree = inventaire.typemouvement == 'ENTREE' %}
{% set refLabels = { APPROVISIONNEMENT: 'Approvisionnement', DEPANNAGE: 'Dépannage', AJUSTEMENT: 'Ajustement' } %}
{% set refTones = { APPROVISIONNEMENT: 'blue', DEPANNAGE: 'orange', AJUSTEMENT: 'purple' } %}

{% block body %}
<div class="max-w-[820px] mx-auto">

    {# En-tête #}
    <div class="mb-6">
        <a href="{{ path('inventaire.index') }}" class="inline-flex items-center gap-1 text-sm text-muted-foreground hover:text-foreground mb-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Retour aux mouvements
        </a>
        <div class="flex items-center gap-2 flex-wrap mb-0.5">
            <p class="text-xs uppercase tracking-wide text-muted-foreground">Mouvement de stock</p>
            {{ ui.badge((isEntree ? '↑ Entrée' : '↓ Sortie'), isEntree ? 'green' : 'red') }}
        </div>
        <h1 class="text-3xl font-light tracking-[-0.5px] leading-[1.2]">Mouvement #{{ inventaire.id }}</h1>
        <p class="text-sm text-muted-foreground mt-1">{{ inventaire.datemouvement ? inventaire.datemouvement|date('d/m/Y à H:i') : '' }}</p>
    </div>

    {# Quantité (hero) #}
    <div class="card p-5 mb-4">
        <p class="text-xs text-muted-foreground">Quantité du mouvement</p>
        <p class="text-3xl font-semibold tabular-nums mt-0.5 {{ isEntree ? 'text-green-600 dark:text-green-400' : 'text-red-600 dark:text-red-400' }}">
            {{ isEntree ? '+' : '−' }}{{ inventaire.quantite }} <span class="text-sm font-normal text-muted-foreground">unité(s)</span>
        </p>
    </div>

    {# Détail #}
    <div class="card p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
            <div class="min-w-0">
                <p class="text-xs uppercase tracking-wide text-muted-foreground">Type de mouvement</p>
                <div class="mt-1">{{ ui.badge((isEntree ? '↑ Entrée' : '↓ Sortie'), isEntree ? 'green' : 'red') }}</div>
            </div>
            <div class="min-w-0">
                <p class="text-xs uppercase tracking-wide text-muted-foreground">Origine</p>
                <div class="mt-1">{{ ui.badge(refLabels[inventaire.referencetype] ?? inventaire.referencetype, refTones[inventaire.referencetype] ?? 'zinc') }}</div>
            </div>
            {{ ui.field('Pièce', inventaire.pieceName, true) }}
            {{ ui.field('Auteur', (inventaire.createdByNom ?? '') ~ ' ' ~ (inventaire.createdByPrenom ?? '')) }}
            {{ ui.field('Date du mouvement', inventaire.datemouvement ? inventaire.datemouvement|date('d/m/Y à H:i:s') : null) }}
        </div>
    </div>
</div>
{% endblock %}
