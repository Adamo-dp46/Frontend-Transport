{% extends 'app-base.html.twig' %}

{% block title %}Réinitialiser le mot de passe{% endblock %}

{% block body %}
<div class="mb-6 text-center">
    <h1 class="text-2xl font-semibold tracking-tight">Nouveau mot de passe</h1>
    <p class="text-sm text-muted-foreground mt-1">
        Choisissez un mot de passe sécurisé
    </p>
</div>

<div class="card p-4">
    {{ form_start(form) }}
        {{ form_row(form.password.first) }}
        {{ form_row(form.password.second) }}
        {{ form_widget(form.token) }}
        <button type="submit" class="btn btn-primary w-full justify-center">Réinitialiser le mot de passe</button>
    {{ form_end(form) }}
</div>

<div class="mt-5 text-center text-sm text-muted-foreground">
    <a href="{{ path('app_login') }}" class="hover:text-foreground transition-colors">
        ← Retour à la connexion
    </a>
</div>
{% endblock %}